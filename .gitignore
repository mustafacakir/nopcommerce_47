## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ins.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if necessary however generally it will be regenerated when needed
#!**/[Pp]ackages/repositories.config
# NuGet v3's project.json files produces more ignorable files
*.nuget.props
*.nuget.targets

# Microsoft Office build files
*.docstates

# Windows image file caches
Thumbs.db
ehthumbs.db
ehthumbs_vista.db

# Folder config file
Desktop.ini

# Nopcommerce specific (Plugins output)
!Presentation/Nop.Web/Plugins/

# IDE specific files
.idea/
*.iws
*.iml
*.ipr
.claude/

# Generated image thumbnails
Presentation/Nop.Web/wwwroot/images/thumbs/

# Generated assets
Presentation/Nop.Web/wwwroot/css/Slick/

# Plugin binaries (untracked)
Presentation/Nop.Web/Plugins/ExternalAuth.Facebook/
Presentation/Nop.Web/Plugins/MultiFactorAuth.GoogleAuthenticator/
Presentation/Nop.Web/Plugins/Shipping.UPS/*.deps.json

# Custom plugin build output (source is in Plugins/ folder, rebuilt on deploy)
Presentation/Nop.Web/Plugins/Widgets.DonationCatalog/

# Store-specific generated theme CSS (nopCommerce theme customizer output)
Presentation/Nop.Web/Themes/Voyage/Content/css/theme.custom-*.css
