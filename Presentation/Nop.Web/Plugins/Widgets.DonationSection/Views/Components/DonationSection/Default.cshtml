@using Nop.Plugin.Widgets.DonationSection.Models.Public
@using System.Text.Json
@model DonationPublicModel
@{ Layout = ""; }

@if (!Model.Sections.Any()) { return; }

@{
    var itemsJson = JsonSerializer.Serialize(Model.AllItems.Select(i => new {
        id                  = i.Id,
        sectionId           = i.SectionId,
        name                = i.Name,
        price               = i.Price,
        priceFormatted      = i.PriceFormatted,
        productId           = i.ProductId,
        customerEntersPrice = i.CustomerEntersPrice
    }));
    var firstSectionId = Model.FirstSectionId;
}

<form id="ds-cep-form" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="CustomerEnteredPrice" id="ds-cep-form-price" value="0" />
</form>
<div class="ds-wrap">
    <div class="ds-card">

        <!-- Kolon 1: Kategoriler -->
        <div class="ds-col ds-col-cat">
            <div class="ds-col-head">BAĞIŞ KATEGORİSİ</div>
            <div class="ds-cat-list">
                @foreach (var sec in Model.Sections)
                {
                    <button class="ds-cat-btn@(sec.Id == firstSectionId ? " ds-cat-on" : "")"
                            data-sid="@sec.Id" type="button">
                        @if (!string.IsNullOrEmpty(sec.IconSvg))
                        {
                            <span class="ds-cat-ico">@Html.Raw(sec.IconSvg)</span>
                        }
                        else if (!string.IsNullOrEmpty(sec.IconUrl))
                        {
                            <span class="ds-cat-ico"><img src="@sec.IconUrl" alt="" /></span>
                        }
                        <span class="ds-cat-name">@sec.Name</span>
                    </button>
                }
            </div>
        </div>

        <!-- Kolon 2: Bağış türü -->
        <div class="ds-col ds-col-items">
            <div class="ds-col-head">BAĞIŞ TÜRÜ</div>
            <div class="ds-item-list" id="ds-item-list"></div>
        </div>

        <!-- Kolon 3: Tutar / aksiyon -->
        <div class="ds-col ds-col-action">
            <div class="ds-col-head">BAĞIŞ TUTARI</div>

            <!-- Sabit fiyatlı ürünler için fiyat kartı -->
            <div class="ds-price-card" id="ds-price-card" style="display:none">
                <svg class="ds-price-card-ico" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                <span class="ds-price-card-label">Bağış tutarı</span>
                <span class="ds-price-card-val" id="ds-price-display">—</span>
            </div>

            <!-- Müşteri fiyat giren ürünler için preset + custom input -->
            <div id="ds-cep-panel" style="display:none">
                <div class="ds-preset-row">
                    <button class="ds-preset-btn" data-amount="100" type="button">100 ₺</button>
                    <button class="ds-preset-btn" data-amount="250" type="button">250 ₺</button>
                    <button class="ds-preset-btn" data-amount="500" type="button">500 ₺</button>
                </div>
                <div class="ds-or-divider"><span>veya</span></div>
                <div class="ds-custom-row">
                    <label class="ds-custom-label">Tutar giriniz</label>
                    <div class="ds-custom-input-wrap">
                        <input type="number" id="ds-custom-amount" class="ds-custom-input" placeholder="0" min="1" />
                        <span class="ds-custom-currency">₺</span>
                    </div>
                </div>
            </div>

            <div class="ds-action-btns">
                <button class="ds-btn-donate" id="ds-btn-donate" type="button" disabled>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    <span id="ds-btn-donate-txt">Bağış Yap</span>
                </button>
                <button class="ds-btn-cart" id="ds-btn-cart" type="button" disabled>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    Sepete Ekle
                </button>
            </div>

            <p class="ds-price-note" id="ds-price-note"></p>
        </div>

    </div>
</div>

<style>
.ds-wrap { margin-bottom: 32px; }
.ds-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 2px 20px rgba(0,0,0,.07);
    display: flex;
    overflow: hidden;
    min-height: 360px;
}

/* Kolonlar */
.ds-col { display: flex; flex-direction: column; }
.ds-col-cat   { flex: 0 0 25%; border-right: 1px solid #f0f0f0; }
.ds-col-items { flex: 0 0 25%; border-right: 1px solid #f0f0f0; }
.ds-col-action{ flex: 1; }

.ds-col-head {
    font-size: .7rem;
    font-weight: 700;
    color: #9ca3af;
    letter-spacing: .8px;
    padding: 20px 20px 12px;
    text-transform: uppercase;
    border-bottom: 1px solid #f0f0f0;
}

/* Kategori listesi */
.ds-cat-list { overflow-y: auto; flex: 1; }
.ds-cat-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 20px;
    background: none;
    border: none;
    border-left: 3px solid transparent;
    text-align: left;
    cursor: pointer;
    font-size: .88rem;
    font-weight: 500;
    color: #374151;
    transition: background .15s, border-color .15s, color .15s;
    border-bottom: 1px solid #f9fafb;
}
.ds-cat-btn:hover { background: #f5f7ff; color: #1e40af; }
.ds-cat-btn.ds-cat-on {
    background: #eff6ff;
    border-left-color: #1d4ed8;
    color: #1d4ed8;
    font-weight: 700;
}
.ds-cat-ico { width: 20px; height: 20px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.ds-cat-ico svg { width: 18px; height: 18px; }
.ds-cat-name { flex: 1; }

/* Ürün listesi */
.ds-item-list { padding: 12px 16px; display: flex; flex-direction: column; gap: 8px; overflow-y: auto; flex: 1; }
.ds-item-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 16px;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    cursor: pointer;
    transition: border-color .15s, background .15s;
    background: #fff;
}
.ds-item-row:hover { border-color: #93c5fd; background: #f8faff; }
.ds-item-row.ds-item-on {
    border-color: #1d4ed8;
    background: #1e3a8a;
}
.ds-item-radio {
    width: 16px; height: 16px; flex-shrink: 0;
    border-radius: 50%;
    border: 2px solid #d1d5db;
    background: #fff;
    transition: border-color .15s, background .15s;
    position: relative;
}
.ds-item-row.ds-item-on .ds-item-radio {
    border-color: #fff;
    background: #fff;
}
.ds-item-row.ds-item-on .ds-item-radio::after {
    content: '';
    position: absolute;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #1e3a8a;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
}
.ds-item-name-txt {
    flex: 1;
    font-size: .88rem;
    font-weight: 500;
    color: #374151;
}
.ds-item-row.ds-item-on .ds-item-name-txt { color: #fff; font-weight: 600; }
.ds-item-check {
    color: #fff;
    opacity: 0;
    transition: opacity .15s;
}
.ds-item-row.ds-item-on .ds-item-check { opacity: 1; }

/* Sağ panel */
.ds-col-action { padding: 0; display: flex; flex-direction: column; }
.ds-col-action .ds-col-head { margin-bottom: 0; }
.ds-col-action > *:not(.ds-col-head) { padding-left: 20px; padding-right: 20px; }

/* Sabit fiyat kartı */
.ds-price-card {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #eff6ff;
    border: 1.5px solid #bfdbfe;
    border-radius: 10px;
    padding: 14px 16px;
    margin: 16px 0 0;
}
.ds-price-card-ico { color: #3b82f6; flex-shrink: 0; }
.ds-price-card-label { flex: 1; font-size: .82rem; color: #374151; }
.ds-price-card-val { font-size: 1rem; font-weight: 800; color: #1d4ed8; white-space: nowrap; }

/* Preset tutar butonları */
.ds-preset-row {
    display: flex;
    gap: 8px;
    margin-top: 16px;
}
.ds-preset-btn {
    flex: 1;
    padding: 10px 6px;
    background: #f3f4f6;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    font-size: .88rem;
    font-weight: 700;
    color: #374151;
    cursor: pointer;
    transition: background .15s, border-color .15s, color .15s;
    text-align: center;
}
.ds-preset-btn:hover { background: #eff6ff; border-color: #93c5fd; color: #1d4ed8; }
.ds-preset-btn.ds-preset-on { background: #1d4ed8; border-color: #1d4ed8; color: #fff; }

/* "veya" ayırıcı */
.ds-or-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 14px;
    color: #9ca3af;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .5px;
}
.ds-or-divider::before, .ds-or-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e5e7eb;
}

/* Özel tutar */
.ds-custom-row { margin-top: 14px; }
.ds-custom-label { display: block; font-size: .78rem; font-weight: 600; color: #6b7280; margin-bottom: 6px; }
.ds-custom-input-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
    transition: border-color .15s;
}
.ds-custom-input-wrap:focus-within { border-color: #1d4ed8; }
.ds-custom-input {
    flex: 1;
    border: none;
    outline: none;
    padding: 10px 12px;
    font-size: .95rem;
    font-weight: 600;
    color: #111827;
    background: transparent;
    min-width: 0;
}
.ds-custom-input::-webkit-outer-spin-button,
.ds-custom-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
.ds-custom-input[type=number] { -moz-appearance: textfield; }
.ds-custom-currency {
    padding: 0 12px;
    font-size: .95rem;
    font-weight: 700;
    color: #6b7280;
    background: #f9fafb;
    border-left: 1px solid #e5e7eb;
    height: 100%;
    display: flex;
    align-items: center;
    min-height: 40px;
}

.ds-action-btns {
    display: flex;
    gap: 8px;
    margin-top: 16px;
}
.ds-btn-donate {
    flex: 1;
    display: flex; align-items: center; justify-content: center; gap: 6px;
    padding: 12px 10px;
    background: #f97316; color: #fff;
    border: none; border-radius: 10px;
    font-size: .82rem; font-weight: 700;
    cursor: pointer; transition: background .15s;
}
.ds-btn-donate:hover:not(:disabled) { background: #ea6c0a; }
.ds-btn-donate:disabled { background: #d1d5db; cursor: not-allowed; }

.ds-btn-cart {
    flex: 0 0 auto;
    display: flex; align-items: center; justify-content: center; gap: 6px;
    padding: 12px 14px;
    background: #1d4ed8; color: #fff;
    border: none; border-radius: 10px;
    font-size: .82rem; font-weight: 700;
    cursor: pointer; transition: background .15s;
    white-space: nowrap;
}
.ds-btn-cart:hover:not(:disabled) { background: #1e40af; }
.ds-btn-cart:disabled { background: #d1d5db; cursor: not-allowed; }

.ds-price-note {
    font-size: .75rem;
    color: #6b7280;
    text-align: center;
    margin-top: 10px;
    line-height: 1.4;
    min-height: 1.2em;
}

@@media (max-width: 860px) {
    .ds-card { flex-direction: column; }
    .ds-col-cat { flex: none; border-right: none; border-bottom: 1px solid #f0f0f0; }
    .ds-cat-list { display: flex; flex-wrap: wrap; gap: 4px; padding: 10px; }
    .ds-cat-btn { width: auto; border-left: none; border-bottom: 2px solid transparent; padding: 8px 12px; font-size: .82rem; border-radius: 8px; }
    .ds-cat-btn.ds-cat-on { border-left: none; border-bottom-color: #1d4ed8; background: #eff6ff; }
    .ds-col-items { border-right: none; border-bottom: 1px solid #f0f0f0; }
    .ds-col-action { flex: none; }
}
@@media (max-width: 520px) {
    .ds-action-btns { flex-direction: column; }
}
</style>

<script>
(function () {
    var ALL_ITEMS = @Html.Raw(itemsJson);

    var selectedItem   = null;
    var selectedAmount = 0;

    var itemListEl   = document.getElementById('ds-item-list');
    var priceCard    = document.getElementById('ds-price-card');
    var priceDisplay = document.getElementById('ds-price-display');
    var cepPanel     = document.getElementById('ds-cep-panel');
    var customInput  = document.getElementById('ds-custom-amount');
    var btnDonate    = document.getElementById('ds-btn-donate');
    var btnDonateTxt = document.getElementById('ds-btn-donate-txt');
    var btnCart      = document.getElementById('ds-btn-cart');
    var priceNote    = document.getElementById('ds-price-note');

    function getPresetBtns() { return document.querySelectorAll('#ds-cep-panel .ds-preset-btn'); }

    function formatPrice(p) {
        return p.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' ₺';
    }

    function clearPresets() {
        getPresetBtns().forEach(function (b) { b.classList.remove('ds-preset-on'); });
    }

    function updateActionPanel() {
        var ok = false;
        if (selectedItem) {
            if (selectedItem.customerEntersPrice) {
                ok = selectedAmount > 0;
                btnDonateTxt.textContent = ok ? formatPrice(selectedAmount) + ' Bağış Yap' : 'Bağış Yap';
            } else {
                ok = true;
                btnDonateTxt.textContent = formatPrice(selectedItem.price) + ' Bağış Yap';
            }
        } else {
            btnDonateTxt.textContent = 'Bağış Yap';
        }
        btnDonate.disabled = !ok;
        btnCart.disabled   = !ok;
        priceNote.textContent = '';
    }

    function showPanelFor(item) {
        if (!item) {
            priceCard.style.display = 'none';
            cepPanel.style.display  = 'none';
            return;
        }
        if (item.customerEntersPrice) {
            priceCard.style.display = 'none';
            cepPanel.style.display  = 'block';
        } else {
            priceDisplay.textContent = item.priceFormatted;
            priceCard.style.display  = 'flex';
            cepPanel.style.display   = 'none';
        }
    }

    function selectItem(item) {
        selectedItem   = item;
        selectedAmount = 0;
        clearPresets();
        if (customInput) customInput.value = '';
        showPanelFor(item);
        updateActionPanel();
    }

    // Preset tutar butonları
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('#ds-cep-panel .ds-preset-btn');
        if (!btn) return;
        var active = btn.classList.contains('ds-preset-on');
        var inp = document.getElementById('ds-custom-amount');
        clearPresets();
        if (active) {
            selectedAmount = 0;
            if (inp) inp.value = '';
        } else {
            btn.classList.add('ds-preset-on');
            selectedAmount = parseFloat(btn.dataset.amount);
            if (inp) { inp.value = btn.dataset.amount; inp.focus(); inp.blur(); }
        }
        updateActionPanel();
    });

    // Özel tutar input
    if (customInput) {
        customInput.addEventListener('input', function () {
            clearPresets();
            var v = parseFloat(customInput.value);
            selectedAmount = (isNaN(v) || v <= 0) ? 0 : v;
            updateActionPanel();
        });
    }

    function renderItems(sectionId) {
        selectItem(null);
        var items = ALL_ITEMS.filter(function (i) { return i.sectionId === sectionId; });
        itemListEl.innerHTML = '';
        items.forEach(function (item, idx) {
            var row = document.createElement('div');
            row.className = 'ds-item-row' + (idx === 0 ? ' ds-item-on' : '');
            row.innerHTML =
                '<span class="ds-item-radio"></span>' +
                '<span class="ds-item-name-txt">' + item.name + '</span>' +
                '<svg class="ds-item-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>';
            row.addEventListener('click', function () {
                document.querySelectorAll('.ds-item-row').forEach(function (r) { r.classList.remove('ds-item-on'); });
                row.classList.add('ds-item-on');
                selectItem(item);
            });
            itemListEl.appendChild(row);
            if (idx === 0) selectItem(item);
        });
    }

    // Kategori tıklamaları
    document.querySelectorAll('.ds-cat-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.ds-cat-btn').forEach(function (b) { b.classList.remove('ds-cat-on'); });
            btn.classList.add('ds-cat-on');
            renderItems(parseInt(btn.dataset.sid));
        });
    });

    function addToCart(andGo) {
        if (!selectedItem) return;
        var isCep = selectedItem.customerEntersPrice;
        if (isCep && selectedAmount <= 0) return;

        btnDonate.disabled = true;
        btnCart.disabled   = true;

        // andGo=true ise success'te checkout'a yönlendir
        if (andGo) {
            var origSuccess = AjaxCart.success_process;
            AjaxCart.success_process = function (data) {
                AjaxCart.success_process = origSuccess;
                btnDonate.disabled = false;
                btnCart.disabled   = false;
                if (data && (data.success === true || data.updatetopcartsectionhtml)) {
                    window.location.href = '/onepagecheckout';
                } else {
                    origSuccess.call(AjaxCart, data);
                }
            };
        } else {
            var origSuccess2 = AjaxCart.success_process;
            AjaxCart.success_process = function (data) {
                AjaxCart.success_process = origSuccess2;
                btnDonate.disabled = false;
                btnCart.disabled   = false;
                origSuccess2.call(AjaxCart, data);
            };
        }

        if (isCep) {
            document.getElementById('ds-cep-form-price').value = selectedAmount;
            AjaxCart.addproducttocart_details(
                '/addproducttocart/details/' + selectedItem.productId + '/1',
                '#ds-cep-form'
            );
        } else {
            AjaxCart.addproducttocart_catalog(
                '/addproducttocart/catalog/' + selectedItem.productId + '/1/1'
            );
        }
    }

    btnDonate.addEventListener('click', function () { addToCart(true); });
    btnCart.addEventListener('click',   function () { addToCart(false); });

    renderItems(@firstSectionId);
})();
</script>
