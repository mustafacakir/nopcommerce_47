@model IList<BlogPostModel7Spikes>
@inject IViewComponentSelector viewComponentSelector

<div class="richblog-hp-cards">
    <div class="richblog-hp-header">
        <strong>@T("SevenSpikes.RichBlog.Public.LatestFromBlog")</strong>
        <a href="@Url.RouteUrl("Blog")" class="richblog-hp-viewall">@T("SevenSpikes.RichBlog.Public.ViewAllBlogPosts")</a>
    </div>
    <div class="richblog-hp-grid">
        @foreach (var post in Model)
        {
            <div class="richblog-hp-card">
                @if (!string.IsNullOrWhiteSpace(post.HomePagePictureUrl))
                {
                    <a class="richblog-hp-card-img" href="@Url.RouteUrl("BlogPost", new { SeName = post.SeName })">
                        @if (viewComponentSelector.SelectComponent("LazyLoadImage") != null)
                        {
                            @await Component.InvokeAsync("LazyLoadImage", new (string Key, string Value)[]
                            {
                                ("src", post.HomePagePictureUrl),
                                ("alt", post.Title),
                                ("title", post.Title)
                            })
                        }
                        else
                        {
                            <img src="@post.HomePagePictureUrl" alt="@post.Title" title="@post.Title" />
                        }
                    </a>
                }
                <div class="richblog-hp-card-body">
                    <span class="richblog-hp-card-date">@post.CreatedOn.ToString("dd MMM yyyy")</span>
                    <h3 class="richblog-hp-card-title">
                        <a href="@Url.RouteUrl("BlogPost", new { SeName = post.SeName })">@post.Title</a>
                    </h3>
                    <div class="richblog-hp-card-desc">
                        @Html.Raw(!string.IsNullOrEmpty(post.BodyOverview) ? post.BodyOverview : post.Body)
                    </div>
                    <a href="@Url.RouteUrl("BlogPost", new { SeName = post.SeName })" class="richblog-hp-card-readmore">
                        @T("SevenSpikes.RichBlog.Public.ReadMore")
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<style>
.richblog-hp-cards {
    padding: 32px 0;
}
.richblog-hp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
}
.richblog-hp-header strong {
    font-size: 20px;
    font-weight: 800;
    color: #111827;
}
.richblog-hp-viewall {
    font-size: 13px;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
}
.richblog-hp-viewall:hover { text-decoration: underline; }

.richblog-hp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
@@media (max-width: 900px) {
    .richblog-hp-grid { grid-template-columns: repeat(2, 1fr); }
}
@@media (max-width: 576px) {
    .richblog-hp-grid { grid-template-columns: 1fr; }
}

.richblog-hp-card {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.08);
    background: #fff;
    display: flex;
    flex-direction: column;
    transition: box-shadow .2s, transform .2s;
}
.richblog-hp-card:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,.14);
    transform: translateY(-2px);
}
.richblog-hp-card-img {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #f3f4f6;
}
.richblog-hp-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .35s;
}
.richblog-hp-card:hover .richblog-hp-card-img img { transform: scale(1.04); }

.richblog-hp-card-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
}
.richblog-hp-card-date {
    font-size: 11px;
    color: #9ca3af;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .6px;
    margin-bottom: 8px;
    display: block;
}
.richblog-hp-card-title {
    font-size: 15px;
    font-weight: 700;
    margin: 0 0 10px;
    line-height: 1.45;
}
.richblog-hp-card-title a { color: #111827; text-decoration: none; }
.richblog-hp-card-title a:hover { color: #2563eb; }
.richblog-hp-card-desc {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.6;
    flex: 1;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
}
.richblog-hp-card-desc p { margin: 0; }
.richblog-hp-card-readmore {
    display: inline-block;
    margin-top: 16px;
    padding: 8px 18px;
    background: #2563eb;
    color: #fff !important;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    text-decoration: none !important;
    align-self: flex-start;
    transition: background .15s;
}
.richblog-hp-card-readmore:hover { background: #1d4ed8; }
</style>
