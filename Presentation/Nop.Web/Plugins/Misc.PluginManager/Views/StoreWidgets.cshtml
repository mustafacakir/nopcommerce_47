@model List<Nop.Plugin.Misc.PluginManager.Models.StoreWidgetEntry>
@{ Layout = "_AdminLayout"; }

<div class="content-header clearfix">
    <h1 class="float-left">Mağaza Widgetları</h1>
</div>

<div class="content">
    <div class="card card-default">
        <div class="card-body">
            @if (!Model.Any())
            {
                <p class="text-muted">Yapılandırılabilir widget bulunamadı.</p>
            }
            else
            {
                <div class="row">
                    @foreach (var w in Model)
                    {
                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="card h-100" style="border:1px solid #e5e7eb;border-radius:10px">
                                <div class="card-body d-flex flex-column" style="gap:10px">
                                    <div>
                                        <span class="badge badge-secondary" style="font-size:.72rem;margin-bottom:6px">@w.Group</span>
                                        <h5 class="card-title" style="font-size:.95rem;font-weight:700;margin:0">@w.FriendlyName</h5>
                                        @if (!string.IsNullOrEmpty(w.Description))
                                        {
                                            <p class="card-text text-muted" style="font-size:.8rem;margin-top:4px">@w.Description</p>
                                        }
                                    </div>
                                    <div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:auto">
                                        @foreach (var store in w.StoreNames)
                                        {
                                            <span style="font-size:.72rem;background:#eff6ff;color:#1d4ed8;border-radius:4px;padding:2px 8px;font-weight:600">@store</span>
                                        }
                                    </div>
                                    <a href="@w.ConfigureUrl" class="btn btn-primary btn-sm" style="margin-top:8px">
                                        <i class="fas fa-cog"></i> Yapılandır
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
