@model Nop.Plugin.Widgets.HeroBanner.Models.PublicInfoModel
@{ Layout = ""; }

<section class="hb-section">

    <div class="hb-bg-shape hb-bg-shape--1"></div>
    <div class="hb-bg-shape hb-bg-shape--2"></div>

    <div class="hb-container">

        <!-- Left: content -->
        <div class="hb-content">
            <div class="hb-badge">
                <span class="hb-badge__dot"></span>
                Güvenilir &amp; Şeffaf Bağış Platformu
            </div>

            <h1 class="hb-title">@Model.Title</h1>
            <p class="hb-subtitle">@Model.Subtitle</p>

            <div class="hb-actions">
                @if (!string.IsNullOrEmpty(Model.ButtonText))
                {
                    <a href="@Model.ButtonUrl" class="hb-btn hb-btn--primary">
                        <span>@Model.ButtonText</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                }
            </div>
        </div>

        <!-- Right: visual -->
        <div class="hb-visual">
            <div class="hb-img-wrap">
                @if (!string.IsNullOrEmpty(Model.BackgroundImageUrl))
                {
                    <img class="hb-img" src="@Model.BackgroundImageUrl" alt="@Model.Title" />
                }
                else
                {
                    <div class="hb-img-placeholder">
                        <svg class="hb-illustration" viewBox="0 0 480 360" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <!-- Background circles -->
                            <circle cx="240" cy="180" r="155" fill="#fff0f1" />
                            <circle cx="240" cy="180" r="115" fill="#ffe0e3" />

                            <!-- Giving hands -->
                            <g transform="translate(145,145)">
                                <!-- Left hand -->
                                <path d="M30 90 Q10 70 15 45 Q18 28 35 30 Q38 15 52 18 Q54 8 66 12 Q70 4 80 10 L80 60 Q65 58 55 70 Z" fill="#e43d51" opacity="0.85"/>
                                <!-- Right hand -->
                                <path d="M160 90 Q180 70 175 45 Q172 28 155 30 Q152 15 138 18 Q136 8 124 12 Q120 4 110 10 L110 60 Q125 58 135 70 Z" fill="#e43d51" opacity="0.85"/>
                                <!-- Heart on palms -->
                                <path d="M95 35 C95 25 80 15 75 28 C70 15 55 25 55 35 C55 50 75 65 75 65 C75 65 95 50 95 35Z" fill="#fff" />
                                <!-- Palm base -->
                                <rect x="30" y="88" width="50" height="14" rx="7" fill="#c0392b" opacity="0.7"/>
                                <rect x="110" y="88" width="50" height="14" rx="7" fill="#c0392b" opacity="0.7"/>
                            </g>

                            <!-- Orbiting icons - top left: home -->
                            <g transform="translate(88,90)">
                                <circle cx="0" cy="0" r="28" fill="#fff" filter="url(#hb-shadow)"/>
                                <path d="M-10 6 L0 -10 L10 6" stroke="#e43d51" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                                <rect x="-8" y="6" width="16" height="10" rx="1.5" stroke="#e43d51" stroke-width="2.5" fill="none"/>
                            </g>

                            <!-- Top right: water drop -->
                            <g transform="translate(392,95)">
                                <circle cx="0" cy="0" r="28" fill="#fff" filter="url(#hb-shadow)"/>
                                <path d="M0 -12 C-10 -2 -13 6 -13 10 A13 13 0 0 0 13 10 C13 6 10 -2 0 -12Z" stroke="#e43d51" stroke-width="2.5" fill="none" stroke-linejoin="round"/>
                            </g>

                            <!-- Bottom left: book -->
                            <g transform="translate(78,275)">
                                <circle cx="0" cy="0" r="28" fill="#fff" filter="url(#hb-shadow)"/>
                                <rect x="-11" y="-11" width="22" height="22" rx="2" stroke="#e43d51" stroke-width="2.5" fill="none"/>
                                <line x1="0" y1="-11" x2="0" y2="11" stroke="#e43d51" stroke-width="2"/>
                                <line x1="-8" y1="-5" x2="-2" y2="-5" stroke="#e43d51" stroke-width="1.5"/>
                                <line x1="-8" y1="1" x2="-2" y2="1" stroke="#e43d51" stroke-width="1.5"/>
                            </g>

                            <!-- Bottom right: food/plate -->
                            <g transform="translate(402,272)">
                                <circle cx="0" cy="0" r="28" fill="#fff" filter="url(#hb-shadow)"/>
                                <circle cx="0" cy="2" r="11" stroke="#e43d51" stroke-width="2.5" fill="none"/>
                                <line x1="-14" y1="2" x2="14" y2="2" stroke="#e43d51" stroke-width="2"/>
                                <line x1="0" y1="-13" x2="0" y2="-7" stroke="#e43d51" stroke-width="2" stroke-linecap="round"/>
                            </g>

                            <!-- Small decorative dots -->
                            <circle cx="165" cy="75"  r="5" fill="#e43d51" opacity="0.25"/>
                            <circle cx="315" cy="75"  r="5" fill="#e43d51" opacity="0.25"/>
                            <circle cx="150" cy="290" r="5" fill="#e43d51" opacity="0.25"/>
                            <circle cx="330" cy="290" r="5" fill="#e43d51" opacity="0.25"/>
                            <circle cx="240" cy="50"  r="4" fill="#e43d51" opacity="0.15"/>
                            <circle cx="240" cy="310" r="4" fill="#e43d51" opacity="0.15"/>

                            <defs>
                                <filter id="hb-shadow" x="-30%" y="-30%" width="160%" height="160%">
                                    <feDropShadow dx="0" dy="3" stdDeviation="5" flood-color="#00000018"/>
                                </filter>
                            </defs>
                        </svg>
                    </div>
                }
                <div class="hb-img-overlay"></div>
            </div>

            <!-- Floating card -->
            <div class="hb-float-card hb-float-card--top">
                <div class="hb-float-card__icon">@Model.Stat1Icon</div>
                <div class="hb-float-card__body">
                    <span class="hb-float-card__num">@Model.Stat1Value</span>
                    <span class="hb-float-card__label">@Model.Stat1Label</span>
                </div>
            </div>

            <div class="hb-float-card hb-float-card--bottom">
                <div class="hb-float-card__icon">@Model.Stat2Icon</div>
                <div class="hb-float-card__body">
                    <span class="hb-float-card__num">@Model.Stat2Value</span>
                    <span class="hb-float-card__label">@Model.Stat2Label</span>
                </div>
            </div>

            <div class="hb-dots">
                @for (int i = 0; i < 12; i++) { <span></span> }
            </div>
        </div>

    </div>
</section>

<style>
    .hb-section {
        position: relative;
        background: #fff;
        padding: 64px 24px 72px 0;
        overflow: hidden;
    }

    /* Background decorative shapes */
    .hb-bg-shape {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }
    .hb-bg-shape--1 {
        width: 600px; height: 600px;
        top: -200px; right: -150px;
        background: radial-gradient(circle, #ffe5e8 0%, transparent 70%);
        opacity: 0.6;
    }
    .hb-bg-shape--2 {
        width: 300px; height: 300px;
        bottom: -120px; left: -80px;
        background: radial-gradient(circle, #f0f4ff 0%, transparent 70%);
        opacity: 0.8;
    }

    .hb-container {
        position: relative;
        z-index: 2;
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
        align-items: center;
    }

    /* ── Badge ── */
    .hb-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #fff5f6;
        border: 1.5px solid #ffd0d5;
        color: #c0392b;
        font-size: 12.5px;
        font-weight: 700;
        padding: 7px 16px;
        border-radius: 20px;
        margin-bottom: 24px;
        letter-spacing: 0.3px;
    }
    .hb-badge__dot {
        width: 7px; height: 7px;
        background: #e43d51;
        border-radius: 50%;
        animation: hb-pulse 1.8s ease-in-out infinite;
        flex-shrink: 0;
    }
    @@keyframes hb-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.5; transform: scale(0.7); }
    }

    /* ── Title ── */
    .hb-title {
        font-size: clamp(32px, 4vw, 52px);
        font-weight: 900;
        color: #1a1a1a;
        line-height: 1.12;
        margin: 0 0 18px;
        letter-spacing: -0.5px;
    }

    /* ── Subtitle ── */
    .hb-subtitle {
        font-size: 16px;
        color: #666;
        line-height: 1.7;
        margin: 0 0 36px;
        max-width: 460px;
    }

    /* ── Actions ── */
    .hb-actions {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 40px;
    }
    .hb-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 28px;
        border-radius: 50px;
        font-size: 15px;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
        white-space: nowrap;
    }
    .hb-btn--primary {
        background: linear-gradient(135deg, #e43d51, #c0392b);
        color: #fff;
        box-shadow: 0 8px 24px rgba(228,61,81,0.35);
    }
    .hb-btn--primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(228,61,81,0.45);
        color: #fff;
    }

    /* ── Trust row ── */
    .hb-trust {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }
    .hb-trust__item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12.5px;
        font-weight: 600;
        color: #888;
    }
    .hb-trust__icon {
        width: 15px; height: 15px;
        stroke: #e43d51;
        flex-shrink: 0;
    }

    /* ── Visual / right side ── */
    .hb-visual {
        position: relative;
    }

    /* Image wrapper */
    .hb-img-wrap {
        position: relative;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0,0,0,0.14);
        aspect-ratio: 4/3;
    }
    .hb-img {
        width: 100%; height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.6s ease;
    }
    .hb-img-wrap:hover .hb-img { transform: scale(1.03); }
    .hb-img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.25) 0%, transparent 50%);
    }
    .hb-img-placeholder {
        width: 100%; height: 100%;
        min-height: 320px;
        background: linear-gradient(135deg, #fff5f6 0%, #f0f4ff 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    .hb-illustration {
        width: 100%;
        max-width: 440px;
        height: auto;
    }

    /* Floating cards */
    .hb-float-card {
        position: absolute;
        background: #fff;
        border-radius: 14px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 8px 28px rgba(0,0,0,0.12);
        white-space: nowrap;
        animation: hb-float 3s ease-in-out infinite;
    }
    .hb-float-card--top {
        top: -20px; left: -28px;
        animation-delay: 0s;
    }
    .hb-float-card--bottom {
        bottom: -20px; right: -24px;
        animation-delay: 1.5s;
    }
    @@keyframes hb-float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-6px); }
    }
    .hb-float-card__icon { font-size: 28px; line-height: 1; }
    .hb-float-card__body {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }
    .hb-float-card__num {
        font-size: 18px;
        font-weight: 900;
        color: #1a1a1a;
        line-height: 1;
    }
    .hb-float-card__label {
        font-size: 11.5px;
        font-weight: 600;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Dots grid decoration */
    .hb-dots {
        position: absolute;
        bottom: -32px; left: -40px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
        z-index: -1;
        pointer-events: none;
    }
    .hb-dots span {
        width: 6px; height: 6px;
        background: #e43d51;
        border-radius: 50%;
        opacity: 0.2;
    }

    /* ── Responsive ── */
    @@media (max-width: 1023px) {
        .hb-container { gap: 40px; }
        .hb-title { font-size: 36px; }
    }
    @@media (max-width: 767px) {
        .hb-section { padding: 48px 20px 56px 20px; }
        .hb-container {
            grid-template-columns: 1fr;
            gap: 48px;
        }
        .hb-visual { order: -1; }
        .hb-float-card--top  { top: -14px; left: -10px; }
        .hb-float-card--bottom { bottom: -14px; right: -10px; }
        .hb-title { font-size: 30px; text-align: center; }
        .hb-subtitle { font-size: 15px; text-align: center; max-width: 100%; }
        .hb-badge { margin-left: auto; margin-right: auto; }
        .hb-actions { justify-content: center; }
        .hb-content { display: flex; flex-direction: column; align-items: center; text-align: center; }
    }
</style>
