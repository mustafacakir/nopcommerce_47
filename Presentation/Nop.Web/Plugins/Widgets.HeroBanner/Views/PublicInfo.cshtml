@model Nop.Plugin.Widgets.HeroBanner.Models.PublicInfoModel
@{ Layout = ""; }

<section class="hb-section">

    <div class="hb-bg-shape hb-bg-shape--1"></div>
    <div class="hb-bg-shape hb-bg-shape--2"></div>

    <div class="hb-container">

        <!-- Left: content -->
        <div class="hb-content">
            <div class="hb-badge">
                <span class="hb-badge__dot"></span>
                Güvenilir &amp; Şeffaf Bağış Platformu
            </div>

            <h1 class="hb-title">@Model.Title</h1>
            <p class="hb-subtitle">@Model.Subtitle</p>

            <div class="hb-actions">
                @if (!string.IsNullOrEmpty(Model.ButtonText))
                {
                    <a href="@Model.ButtonUrl" class="hb-btn hb-btn--primary">
                        <span>@Model.ButtonText</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                }
                <a href="#" class="hb-btn hb-btn--ghost">Nasıl Çalışır?</a>
            </div>

            <div class="hb-trust">
                <div class="hb-trust__item">
                    <svg class="hb-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    Güvenli Ödeme
                </div>
                <div class="hb-trust__item">
                    <svg class="hb-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    Vergi Muafiyeti
                </div>
                <div class="hb-trust__item">
                    <svg class="hb-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Anında İletim
                </div>
            </div>
        </div>

        <!-- Right: visual -->
        <div class="hb-visual">
            <div class="hb-img-wrap">
                @if (!string.IsNullOrEmpty(Model.BackgroundImageUrl))
                {
                    <img class="hb-img" src="@Model.BackgroundImageUrl" alt="@Model.Title" />
                }
                else
                {
                    <div class="hb-img-placeholder">
                        <div class="hb-placeholder-icon">🤲</div>
                    </div>
                }
                <div class="hb-img-overlay"></div>
            </div>

            <!-- Floating card -->
            <div class="hb-float-card hb-float-card--top">
                <div class="hb-float-card__icon">❤️</div>
                <div class="hb-float-card__body">
                    <span class="hb-float-card__num">10.000+</span>
                    <span class="hb-float-card__label">Mutlu Aile</span>
                </div>
            </div>

            <div class="hb-float-card hb-float-card--bottom">
                <div class="hb-float-card__icon">🌍</div>
                <div class="hb-float-card__body">
                    <span class="hb-float-card__num">40+</span>
                    <span class="hb-float-card__label">Ülkede Yardım</span>
                </div>
            </div>

            <div class="hb-dots">
                @for (int i = 0; i < 12; i++) { <span></span> }
            </div>
        </div>

    </div>
</section>

<style>
    .hb-section {
        position: relative;
        background: #fff;
        padding: 64px 24px 72px;
        overflow: hidden;
    }

    /* Background decorative shapes */
    .hb-bg-shape {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }
    .hb-bg-shape--1 {
        width: 600px; height: 600px;
        top: -200px; right: -150px;
        background: radial-gradient(circle, #ffe5e8 0%, transparent 70%);
        opacity: 0.6;
    }
    .hb-bg-shape--2 {
        width: 300px; height: 300px;
        bottom: -120px; left: -80px;
        background: radial-gradient(circle, #f0f4ff 0%, transparent 70%);
        opacity: 0.8;
    }

    .hb-container {
        position: relative;
        z-index: 2;
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
        align-items: center;
    }

    /* ── Badge ── */
    .hb-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #fff5f6;
        border: 1.5px solid #ffd0d5;
        color: #c0392b;
        font-size: 12.5px;
        font-weight: 700;
        padding: 7px 16px;
        border-radius: 20px;
        margin-bottom: 24px;
        letter-spacing: 0.3px;
    }
    .hb-badge__dot {
        width: 7px; height: 7px;
        background: #e43d51;
        border-radius: 50%;
        animation: hb-pulse 1.8s ease-in-out infinite;
        flex-shrink: 0;
    }
    @@keyframes hb-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.5; transform: scale(0.7); }
    }

    /* ── Title ── */
    .hb-title {
        font-size: clamp(32px, 4vw, 52px);
        font-weight: 900;
        color: #1a1a1a;
        line-height: 1.12;
        margin: 0 0 18px;
        letter-spacing: -0.5px;
    }

    /* ── Subtitle ── */
    .hb-subtitle {
        font-size: 16px;
        color: #666;
        line-height: 1.7;
        margin: 0 0 36px;
        max-width: 460px;
    }

    /* ── Actions ── */
    .hb-actions {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 40px;
    }
    .hb-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 28px;
        border-radius: 50px;
        font-size: 15px;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
        white-space: nowrap;
    }
    .hb-btn--primary {
        background: linear-gradient(135deg, #e43d51, #c0392b);
        color: #fff;
        box-shadow: 0 8px 24px rgba(228,61,81,0.35);
    }
    .hb-btn--primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(228,61,81,0.45);
        color: #fff;
    }
    .hb-btn--ghost {
        background: transparent;
        color: #555;
        border: 2px solid #e0e0e0;
    }
    .hb-btn--ghost:hover {
        border-color: #e43d51;
        color: #e43d51;
        transform: translateY(-2px);
    }

    /* ── Trust row ── */
    .hb-trust {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }
    .hb-trust__item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12.5px;
        font-weight: 600;
        color: #888;
    }
    .hb-trust__icon {
        width: 15px; height: 15px;
        stroke: #e43d51;
        flex-shrink: 0;
    }

    /* ── Visual / right side ── */
    .hb-visual {
        position: relative;
    }

    /* Image wrapper */
    .hb-img-wrap {
        position: relative;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0,0,0,0.14);
        aspect-ratio: 4/3;
    }
    .hb-img {
        width: 100%; height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.6s ease;
    }
    .hb-img-wrap:hover .hb-img { transform: scale(1.03); }
    .hb-img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.25) 0%, transparent 50%);
    }
    .hb-img-placeholder {
        width: 100%; height: 100%;
        min-height: 320px;
        background: linear-gradient(135deg, #fff0f1 0%, #f0f4ff 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .hb-placeholder-icon {
        font-size: 80px;
        filter: drop-shadow(0 8px 16px rgba(228,61,81,0.2));
    }

    /* Floating cards */
    .hb-float-card {
        position: absolute;
        background: #fff;
        border-radius: 14px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 8px 28px rgba(0,0,0,0.12);
        white-space: nowrap;
        animation: hb-float 3s ease-in-out infinite;
    }
    .hb-float-card--top {
        top: -20px; left: -28px;
        animation-delay: 0s;
    }
    .hb-float-card--bottom {
        bottom: -20px; right: -24px;
        animation-delay: 1.5s;
    }
    @@keyframes hb-float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-6px); }
    }
    .hb-float-card__icon { font-size: 28px; line-height: 1; }
    .hb-float-card__body {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }
    .hb-float-card__num {
        font-size: 18px;
        font-weight: 900;
        color: #1a1a1a;
        line-height: 1;
    }
    .hb-float-card__label {
        font-size: 11.5px;
        font-weight: 600;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Dots grid decoration */
    .hb-dots {
        position: absolute;
        bottom: -32px; left: -40px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
        z-index: -1;
        pointer-events: none;
    }
    .hb-dots span {
        width: 6px; height: 6px;
        background: #e43d51;
        border-radius: 50%;
        opacity: 0.2;
    }

    /* ── Responsive ── */
    @@media (max-width: 1023px) {
        .hb-container { gap: 40px; }
        .hb-title { font-size: 36px; }
    }
    @@media (max-width: 767px) {
        .hb-section { padding: 48px 20px 56px; }
        .hb-container {
            grid-template-columns: 1fr;
            gap: 48px;
        }
        .hb-visual { order: -1; }
        .hb-float-card--top  { top: -14px; left: -10px; }
        .hb-float-card--bottom { bottom: -14px; right: -10px; }
        .hb-title { font-size: 30px; }
        .hb-subtitle { font-size: 15px; }
    }
</style>
