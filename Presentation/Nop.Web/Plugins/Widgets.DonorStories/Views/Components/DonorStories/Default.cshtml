@model Nop.Plugin.Widgets.DonorStories.Models.PublicInfoModel
@{ Layout = ""; }

@if (Model.Stories.Any())
{
    <section class="ds-section">
        <div class="ds-inner">
            <h2 class="ds-title">@Model.SectionTitle</h2>
            <div class="ds-carousel" id="dsCarousel">
                <div class="ds-track" id="dsTrack">
                    @foreach (var story in Model.Stories)
                    {
                        <div class="ds-card">
                            <div class="ds-quote-icon">"</div>
                            <p class="ds-quote">@story.Quote</p>
                            <div class="ds-author">
                                @if (!string.IsNullOrEmpty(story.Avatar))
                                {
                                    <img src="@story.Avatar" class="ds-avatar" alt="@story.Name" />
                                }
                                else
                                {
                                    <div class="ds-avatar ds-avatar-initials">@story.Initials</div>
                                }
                                <div class="ds-author-info">
                                    <strong>@story.Name</strong>
                                    @if (!string.IsNullOrEmpty(story.Location))
                                    {
                                        <span>📍 @story.Location</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            @if (Model.Stories.Count > 1)
            {
                <div class="ds-dots" id="dsDots">
                    @for (int i = 0; i < Model.Stories.Count; i++)
                    {
                        <button class="ds-dot @(i == 0 ? "active" : "")" data-index="@i" type="button"></button>
                    }
                </div>
            }
        </div>
    </section>
}

<style>
    .ds-section {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        padding: 56px 0;
    }
    .ds-inner {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 24px;
    }
    .ds-title {
        text-align: center;
        color: #fff;
        font-size: 28px;
        font-weight: 900;
        margin: 0 0 36px;
    }
    .ds-carousel { overflow: hidden; }
    .ds-track {
        display: flex;
        gap: 24px;
        transition: transform 0.4s ease;
    }
    .ds-card {
        flex: 0 0 100%;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 16px;
        padding: 32px;
        box-sizing: border-box;
    }
    .ds-quote-icon {
        font-size: 64px;
        color: #e43d51;
        line-height: 0.5;
        margin-bottom: 16px;
        font-family: Georgia, serif;
    }
    .ds-quote {
        color: rgba(255,255,255,0.85);
        font-size: 16px;
        line-height: 1.7;
        margin: 0 0 24px;
        font-style: italic;
    }
    .ds-author {
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .ds-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }
    .ds-avatar-initials {
        background: #e43d51;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: 800;
    }
    .ds-author-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .ds-author-info strong {
        color: #fff;
        font-size: 15px;
    }
    .ds-author-info span {
        color: rgba(255,255,255,0.5);
        font-size: 12px;
    }
    .ds-dots {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-top: 24px;
    }
    .ds-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255,255,255,0.3);
        border: none;
        cursor: pointer;
        transition: background 0.2s;
        padding: 0;
    }
    .ds-dot.active { background: #e43d51; }
</style>

<script>
(function () {
    var track = document.getElementById('dsTrack');
    var dots = document.querySelectorAll('.ds-dot');
    if (!track || !dots.length) return;
    var current = 0;
    var total = dots.length;

    function goTo(idx) {
        current = idx;
        track.style.transform = 'translateX(calc(-' + idx + ' * (100% + 24px)))';
        dots.forEach(function (d, i) { d.classList.toggle('active', i === idx); });
    }

    dots.forEach(function (dot) {
        dot.addEventListener('click', function () { goTo(parseInt(this.dataset.index)); });
    });

    setInterval(function () { goTo((current + 1) % total); }, 5000);
})();
</script>
