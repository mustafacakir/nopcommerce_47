@model Nop.Plugin.Widgets.DonorStories.Models.PublicInfoModel
@{ Layout = ""; }

@if (Model.Stories.Any())
{
    <section class="ds-section">
        <div class="ds-inner">
            <div class="ds-header">
                <div class="ds-badge">Bağışçı Yorumları</div>
                <h2 class="ds-title">@Model.SectionTitle</h2>
            </div>
            <div class="ds-carousel" id="dsCarousel">
                <div class="ds-track" id="dsTrack">
                    @foreach (var story in Model.Stories)
                    {
                        <div class="ds-card">
                            <div class="ds-quote-icon">"</div>
                            <p class="ds-quote">@story.Quote</p>
                            <div class="ds-author">
                                @if (!string.IsNullOrEmpty(story.Avatar))
                                {
                                    <img src="@story.Avatar" class="ds-avatar" alt="@story.Name" />
                                }
                                else
                                {
                                    <div class="ds-avatar ds-avatar-initials">@story.Initials</div>
                                }
                                <div class="ds-author-info">
                                    <strong>@story.Name</strong>
                                    @if (!string.IsNullOrEmpty(story.Location))
                                    {
                                        <span>📍 @story.Location</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            @if (Model.Stories.Count > 1)
            {
                <div class="ds-dots" id="dsDots">
                    @for (int i = 0; i < Model.Stories.Count; i++)
                    {
                        <button class="ds-dot @(i == 0 ? "active" : "")" data-index="@i" type="button"></button>
                    }
                </div>
            }
        </div>
    </section>
}

<style>
.ds-section {
    background: #f8f9fb;
    padding: 72px 0 80px;
    border-top: 1px solid #ebebeb;
    border-bottom: 1px solid #ebebeb;
}
.ds-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
}
.ds-header {
    text-align: center;
    margin-bottom: 40px;
}
.ds-badge {
    display: inline-block;
    background: linear-gradient(135deg, #e43d51, #c0392b);
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 16px;
    border-radius: 20px;
    margin-bottom: 14px;
}
.ds-title {
    font-size: 28px;
    font-weight: 900;
    color: #1a1a1a;
    margin: 0;
    line-height: 1.3;
}
.ds-carousel { overflow: hidden; }
.ds-track {
    display: flex;
    gap: 24px;
    transition: transform 0.4s ease;
}
.ds-card {
    flex: 0 0 100%;
    background: #fff;
    border: 1px solid #ebebeb;
    border-radius: 20px;
    padding: 36px 40px;
    box-sizing: border-box;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
}
.ds-quote-icon {
    font-size: 64px;
    color: #e43d51;
    line-height: 0.5;
    margin-bottom: 20px;
    font-family: Georgia, serif;
}
.ds-quote {
    color: #444;
    font-size: 16px;
    line-height: 1.75;
    margin: 0 0 28px;
    font-style: italic;
}
.ds-author {
    display: flex;
    align-items: center;
    gap: 14px;
}
.ds-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 3px solid #f0f0f0;
}
.ds-avatar-initials {
    background: linear-gradient(135deg, #e43d51, #c0392b);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 800;
}
.ds-author-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
}
.ds-author-info strong {
    color: #1a1a1a;
    font-size: 15px;
    font-weight: 800;
}
.ds-author-info span {
    color: #999;
    font-size: 12px;
}
.ds-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
}
.ds-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ddd;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    padding: 0;
}
.ds-dot.active {
    background: #e43d51;
    transform: scale(1.3);
}
</style>

<script>
(function () {
    var track = document.getElementById('dsTrack');
    var dots = document.querySelectorAll('.ds-dot');
    if (!track || !dots.length) return;
    var current = 0;
    var total = dots.length;

    function goTo(idx) {
        current = idx;
        track.style.transform = 'translateX(calc(-' + idx + ' * (100% + 24px)))';
        dots.forEach(function (d, i) { d.classList.toggle('active', i === idx); });
    }

    dots.forEach(function (dot) {
        dot.addEventListener('click', function () { goTo(parseInt(this.dataset.index)); });
    });

    setInterval(function () { goTo((current + 1) % total); }, 5000);
})();
</script>
