@model Nop.Plugin.Widgets.DonationTransparency.Models.ConfigurationModel
@{ Layout = "_ConfigurePlugin"; }

@await Component.InvokeAsync("StoreScopeConfiguration")
<form asp-controller="WidgetsDonationTransparency" asp-action="Configure" method="post">
    <div class="panel-group">
        <div class="panel panel-default">
            <div class="panel-heading">Genel</div>
            <div class="panel-body">
                <div class="form-group row">
                    <div class="col-md-3"><label>Başlık</label></div>
                    <div class="col-md-9"><input type="text" name="SectionTitle" value="@Model.SectionTitle" class="form-control" /></div>
                </div>
                <div class="form-group row">
                    <div class="col-md-3"><label>Alt Başlık</label></div>
                    <div class="col-md-9"><input type="text" name="SectionSubtitle" value="@Model.SectionSubtitle" class="form-control" /></div>
                </div>
                <div class="form-group row">
                    <div class="col-md-3"><label>Rapor Butonu Metni</label></div>
                    <div class="col-md-9"><input type="text" name="ReportLinkText" value="@Model.ReportLinkText" class="form-control" /></div>
                </div>
                <div class="form-group row">
                    <div class="col-md-3"><label>Rapor URL</label></div>
                    <div class="col-md-9"><input type="text" name="ReportLinkUrl" value="@Model.ReportLinkUrl" class="form-control" /></div>
                </div>
            </div>
        </div>
        @foreach (var i in new[] { 1, 2, 3, 4, 5 })
        {
            var lbl = i == 1 ? Model.Item1Label : i == 2 ? Model.Item2Label : i == 3 ? Model.Item3Label : i == 4 ? Model.Item4Label : Model.Item5Label;
            var pct = i == 1 ? Model.Item1Percent : i == 2 ? Model.Item2Percent : i == 3 ? Model.Item3Percent : i == 4 ? Model.Item4Percent : Model.Item5Percent;
            var col = i == 1 ? Model.Item1Color : i == 2 ? Model.Item2Color : i == 3 ? Model.Item3Color : i == 4 ? Model.Item4Color : Model.Item5Color;
            var ico = i == 1 ? Model.Item1Icon : i == 2 ? Model.Item2Icon : i == 3 ? Model.Item3Icon : i == 4 ? Model.Item4Icon : Model.Item5Icon;
            var dsc = i == 1 ? Model.Item1Description : i == 2 ? Model.Item2Description : i == 3 ? Model.Item3Description : i == 4 ? Model.Item4Description : Model.Item5Description;
            <div class="panel panel-default">
                <div class="panel-heading">Kalem @i</div>
                <div class="panel-body">
                    <div class="form-group row">
                        <div class="col-md-3"><label>Etiket</label></div>
                        <div class="col-md-9"><input type="text" name="Item@(i)Label" value="@lbl" class="form-control" /></div>
                    </div>
                    <div class="form-group row">
                        <div class="col-md-3"><label>Yüzde (%)</label></div>
                        <div class="col-md-9"><input type="number" name="Item@(i)Percent" value="@pct" class="form-control" min="0" max="100" /></div>
                    </div>
                    <div class="form-group row">
                        <div class="col-md-3"><label>Renk (hex)</label></div>
                        <div class="col-md-4"><input type="color" name="Item@(i)Color" value="@col" class="form-control" style="height:38px;" /></div>
                    </div>
                    <div class="form-group row">
                        <div class="col-md-3"><label>İkon (emoji)</label></div>
                        <div class="col-md-9"><input type="text" name="Item@(i)Icon" value="@ico" class="form-control" /></div>
                    </div>
                    <div class="form-group row">
                        <div class="col-md-3"><label>Açıklama</label></div>
                        <div class="col-md-9"><input type="text" name="Item@(i)Description" value="@dsc" class="form-control" /></div>
                    </div>
                </div>
            </div>
        }
        <div class="panel panel-default">
            <div class="panel-body">
                <div class="form-group row">
                    <div class="col-md-9 col-md-offset-3">
                        <input type="submit" name="save" class="btn bg-blue" value="@T("Admin.Common.Save")" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
