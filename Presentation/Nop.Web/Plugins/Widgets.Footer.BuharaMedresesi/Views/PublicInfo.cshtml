@model Nop.Plugin.Widgets.Footer.BuharaMedresesi.Models.PublicInfoModel
@{ Layout = ""; }

<!-- Ana Footer -->
<footer class="bf">

    <!-- CTA Banner -->
    <div class="bf-cta-wrap">
        <div class="bf-cta">
            <div class="bf-cta__inner">
                <div class="bf-cta__text">
                    <h2 class="bf-cta__title">@Model.CtaTitle</h2>
                    <p class="bf-cta__subtitle">@Model.CtaSubtitle</p>
                </div>
                <a href="@Model.CtaButtonUrl" class="bf-cta__btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    @Model.CtaButtonText
                </a>
            </div>
        </div>
    </div>
    <div class="bf-top">
        <div class="bf-container">

            <!-- Marka kolonu -->
            <div class="bf-col bf-col--brand">
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <img src="@Model.LogoUrl" alt="Logo" class="bf-logo" />
                }
                <p class="bf-desc">@Model.Description</p>
                <div class="bf-social">
                    @if (!string.IsNullOrEmpty(Model.FacebookUrl) )
                    {
                        <a href="@Model.FacebookUrl" class="bf-social__link" target="_blank" rel="noopener" aria-label="Facebook">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.InstagramUrl))
                    {
                        <a href="@Model.InstagramUrl" class="bf-social__link" target="_blank" rel="noopener" aria-label="Instagram">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.TwitterUrl))
                    {
                        <a href="@Model.TwitterUrl" class="bf-social__link" target="_blank" rel="noopener" aria-label="X">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.YoutubeUrl))
                    {
                        <a href="@Model.YoutubeUrl" class="bf-social__link" target="_blank" rel="noopener" aria-label="YouTube">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 7s-.3-1.9-1.2-2.7c-1.1-1.2-2.4-1.2-3-1.3C16.2 3 12 3 12 3s-4.2 0-6.8.2c-.6.1-1.9.1-3 1.3C1.3 5.3 1 7 1 7S.7 9.1.7 11.2v2c0 2.1.3 4.2.3 4.2s.3 1.9 1.2 2.7c1.1 1.2 2.6 1.1 3.3 1.2C7.2 21.5 12 21.5 12 21.5s4.2 0 6.8-.2c.6-.1 1.9-.1 3-1.3.9-.8 1.2-2.7 1.2-2.7s.3-2.1.3-4.2v-2C23.3 9.1 23 7 23 7zM9.7 15.5V8.4l8.1 3.6-8.1 3.5z"/></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.LinkedinUrl))
                    {
                        <a href="@Model.LinkedinUrl" class="bf-social__link" target="_blank" rel="noopener" aria-label="LinkedIn">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.TiktokUrl))
                    {
                        <a href="@Model.TiktokUrl" class="bf-social__link" target="_blank" rel="noopener" aria-label="TikTok">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.5a8.18 8.18 0 0 0 4.79 1.54V6.59a4.85 4.85 0 0 1-1.02.1z"/></svg>
                        </a>
                    }
                </div>
            </div>

            <!-- Hızlı Linkler -->
            <div class="bf-col">
                <h4 class="bf-col__title">@Model.QuickLinksTitle</h4>
                <ul class="bf-links">
                    @foreach (var link in Model.QuickLinks)
                    {
                        <li><a href="@link.Url">@link.Text</a></li>
                    }
                </ul>
            </div>

            <!-- Proje Kategorileri -->
            <div class="bf-col">
                <h4 class="bf-col__title">@Model.CategoryLinksTitle</h4>
                <ul class="bf-links">
                    @foreach (var link in Model.CategoryLinks)
                    {
                        <li><a href="@link.Url">@link.Text</a></li>
                    }
                </ul>
            </div>

            <!-- İletişim -->
            <div class="bf-col">
                <h4 class="bf-col__title">@Model.ContactTitle</h4>
                <ul class="bf-contact">
                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <li>
                            <span class="bf-contact__icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            </span>
                            <span>@Model.Address</span>
                        </li>
                    }
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <li>
                            <span class="bf-contact__icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            </span>
                            <a href="tel:@Model.Phone.Replace(" ", "")">@Model.Phone</a>
                        </li>
                    }
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <li>
                            <span class="bf-contact__icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            </span>
                            <a href="mailto:@Model.Email">@Model.Email</a>
                        </li>
                    }
                </ul>
            </div>

        </div>
    </div>

    <!-- Alt çubuk -->
    <div class="bf-bottom">
        <div class="bf-bottom__inner">
            <span class="bf-copy">@Model.CopyrightText</span>
            <div class="bf-legal">
                @if (!string.IsNullOrEmpty(Model.KvkkUrl))
                {
                    <a href="@Model.KvkkUrl">KVKK Aydınlatma Metni</a>
                }
                @if (!string.IsNullOrEmpty(Model.GizlilikUrl))
                {
                    <a href="@Model.GizlilikUrl">Gizlilik Politikası</a>
                }
            </div>
        </div>
    </div>
</footer>

<style>
    /* ── CTA Banner ── */
    .bf-cta-wrap {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 24px;
        position: relative;
        top: -40px;
        margin-bottom: -40px;
    }
    .bf-cta {
        background: linear-gradient(135deg, #1565c0 0%, #1976d2 60%, #42a5f5 100%);
        padding: 32px 40px;
        border-radius: 16px;
    }
    .bf-cta__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
    }
    .bf-cta__title {
        font-size: 24px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 6px;
        font-family: 'Poppins', sans-serif;
    }
    .bf-cta__subtitle {
        font-size: 14px;
        color: rgba(255,255,255,0.85);
        margin: 0;
        font-family: 'Poppins', sans-serif;
    }
    .bf-cta__btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #fff;
        color: #1565c0;
        font-size: 14px;
        font-weight: 700;
        padding: 12px 28px;
        border-radius: 50px;
        text-decoration: none;
        white-space: nowrap;
        flex-shrink: 0;
        font-family: 'Poppins', sans-serif;
        transition: box-shadow 0.2s, transform 0.2s;
    }
    .bf-cta__btn:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.15); transform: translateY(-1px); color: #1565c0; }

    /* ── Footer ── */
    .bf {
        background: #1a2370;
        color: #a8b4d8;
        font-family: 'Poppins', sans-serif;
    }

    .bf-top { padding: 80px 24px 48px; }

    .bf-container {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr 1fr;
        gap: 48px;
    }

    /* Marka */
    .bf-logo { max-height: 60px; width: auto; margin-bottom: 20px; display: block; }
    .bf-desc {
        font-size: 13.5px;
        line-height: 1.7;
        color: #8899cc;
        margin: 0 0 24px;
    }
    .bf-social { display: flex; gap: 10px; flex-wrap: wrap; }
    .bf-social__link {
        width: 38px; height: 38px;
        border-radius: 50%;
        background: rgba(255,255,255,0.08);
        display: flex; align-items: center; justify-content: center;
        color: #a8b4d8;
        transition: background 0.2s, color 0.2s;
    }
    .bf-social__link svg { width: 17px; height: 17px; }
    .bf-social__link:hover { background: #1976d2; color: #fff; }

    /* Kolonlar */
    .bf-col__title {
        font-size: 15px;
        font-weight: 700;
        color: #fff;
        margin: 0 0 20px;
    }
    .bf-links {
        list-style: none; margin: 0; padding: 0;
        display: flex; flex-direction: column; gap: 12px;
    }
    .bf-links a { font-size: 13.5px; color: #8899cc; text-decoration: none; transition: color 0.18s; }
    .bf-links a:hover { color: #fff; }

    /* İletişim */
    .bf-contact { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 16px; }
    .bf-contact li { display: flex; align-items: flex-start; gap: 12px; font-size: 13.5px; color: #8899cc; }
    .bf-contact__icon {
        width: 36px; height: 36px; flex-shrink: 0;
        background: rgba(255,255,255,0.08);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
    }
    .bf-contact__icon svg { width: 16px; height: 16px; stroke: #42a5f5; }
    .bf-contact a { color: #8899cc; text-decoration: none; }
    .bf-contact a:hover { color: #fff; }

    /* Alt çubuk */
    .bf-bottom {
        border-top: 1px solid rgba(255,255,255,0.08);
        padding: 18px 24px;
    }
    .bf-bottom__inner {
        max-width: 1180px; margin: 0 auto;
        display: flex; align-items: center; justify-content: space-between; gap: 16px;
    }
    .bf-copy { font-size: 13px; color: #5566a0; }
    .bf-legal { display: flex; gap: 24px; }
    .bf-legal a { font-size: 13px; color: #5566a0; text-decoration: none; transition: color 0.18s; }
    .bf-legal a:hover { color: #fff; }

    /* Responsive */
    @@media (max-width: 960px) {
        .bf-container { grid-template-columns: 1fr 1fr; gap: 36px; }
        .bf-col--brand { grid-column: 1 / -1; }
        .bf-cta__inner { flex-direction: column; align-items: flex-start; }
    }
    @@media (max-width: 560px) {
        .bf-top { padding: 72px 16px 32px; }
        .bf-container { grid-template-columns: 1fr; gap: 28px; }
        .bf-bottom__inner { flex-direction: column; align-items: flex-start; gap: 10px; }
        .bf-bottom { padding: 18px 16px; }
        .bf-cta-wrap { top: -28px; margin-bottom: -28px; padding: 0 16px; }
        .bf-cta { padding: 24px; border-radius: 12px; }
        .bf-cta__title { font-size: 20px; }
    }
</style>
