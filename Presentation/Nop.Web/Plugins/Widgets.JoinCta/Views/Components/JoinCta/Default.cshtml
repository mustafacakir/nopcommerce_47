@using Nop.Plugin.Widgets.JoinCta.Models
@model PublicModel
@{ Layout = ""; }

<section class="jc-section">
    <div class="jc-container">

        <h2 class="jc-title">@Model.Title</h2>

        <div class="jc-grid">

            <!-- Sol: Havale / EFT -->
            <div class="jc-bank-card">
                <div class="jc-bank-head">
                    <span class="jc-bank-head-ico">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                    </span>
                    <span class="jc-bank-head-txt">@Model.BankSectionTitle</span>
                </div>
                <div class="jc-bank-list">
                    @foreach (var acc in Model.BankAccounts)
                    {
                        <div class="jc-bank-row">
                            <span class="jc-bank-cur">@acc.Currency</span>
                            <div class="jc-bank-info">
                                <span class="jc-bank-name">@acc.BankName</span>
                                <span class="jc-bank-iban">@acc.Iban</span>
                            </div>
                            <button class="jc-copy-btn" type="button" data-iban="@acc.Iban" title="Kopyala">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                            </button>
                        </div>
                    }
                </div>
            </div>

            <!-- Sağ: kartlar + bülten -->
            <div class="jc-right">

                <div class="jc-cta-row">
                    <!-- Bağış Yap -->
                    <div class="jc-cta-card">
                        <span class="jc-cta-ico jc-cta-ico-donate">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </span>
                        <h3 class="jc-cta-title">@Model.DonateTitle</h3>
                        <p class="jc-cta-desc">@Model.DonateDescription</p>
                        <a href="@Model.DonateUrl" class="jc-cta-link">@Model.DonateLinkText <span>→</span></a>
                    </div>

                    <!-- İletişime Geç -->
                    <div class="jc-cta-card">
                        <span class="jc-cta-ico jc-cta-ico-contact">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        </span>
                        <h3 class="jc-cta-title">@Model.ContactTitle</h3>
                        <p class="jc-cta-desc">@Model.ContactDescription</p>
                        <a href="/contact" class="jc-cta-link">@Model.ContactLinkText <span>→</span></a>
                    </div>
                </div>

                <!-- E-bülten -->
                <div class="jc-newsletter">
                    <p class="jc-nl-label">E-bültenimize abone olun, gelişmelerden haberdar olun</p>
                    @Html.AntiForgeryToken()
                    <div class="jc-nl-form">
                        <span class="jc-nl-ico">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        </span>
                        <input type="email" id="jc-nl-email" class="jc-nl-input" placeholder="E-posta adresiniz" />
                        <button type="button" id="jc-nl-btn" class="jc-nl-btn">Abone Ol <span>→</span></button>
                    </div>
                    <p id="jc-nl-note" class="jc-nl-note">Bilgileriniz güvende. İstediğiniz zaman abonelikten çıkabilirsiniz.</p>
                </div>

            </div>
        </div>

    </div>
</section>

<style>
.jc-section { padding: 60px 20px; width: 100%; box-sizing: border-box; }
.jc-container { max-width: 100%; margin: 0; }

.jc-title {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #111827;
    margin: 0 0 36px;
}

.jc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    align-items: start;
}

/* Havale kartı */
.jc-bank-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
}
.jc-bank-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 18px 20px;
    border-bottom: 1px solid #f0f0f0;
    font-weight: 700;
    font-size: .95rem;
    color: #111827;
}
.jc-bank-head-ico {
    width: 36px; height: 36px;
    background: #eff6ff;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #3b82f6; flex-shrink: 0;
}
.jc-bank-list { padding: 8px 0; }
.jc-bank-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 20px;
    border-bottom: 1px solid #f9fafb;
    transition: background .1s;
}
.jc-bank-row:last-child { border-bottom: none; }
.jc-bank-row:hover { background: #f9fafb; }
.jc-bank-cur {
    flex-shrink: 0;
    min-width: 46px;
    text-align: center;
    font-size: .72rem;
    font-weight: 700;
    color: #374151;
    background: #f3f4f6;
    border-radius: 6px;
    padding: 5px 6px;
}
.jc-bank-info { flex: 1; display: flex; flex-direction: column; gap: 2px; }
.jc-bank-name { font-size: .88rem; font-weight: 600; color: #111827; }
.jc-bank-iban { font-size: .78rem; color: #6b7280; }
.jc-copy-btn {
    flex-shrink: 0;
    width: 32px; height: 32px;
    background: #f3f4f6;
    border: none; border-radius: 7px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: #6b7280;
    transition: background .15s, color .15s;
}
.jc-copy-btn:hover { background: #dbeafe; color: #2563eb; }
.jc-copy-btn.jc-copied { background: #dcfce7; color: #16a34a; }

/* Sağ sütun */
.jc-right { display: flex; flex-direction: column; gap: 20px; }

.jc-cta-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

.jc-cta-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
}
.jc-cta-ico {
    width: 44px; height: 44px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.jc-cta-ico-donate  { background: #eff6ff; color: #3b82f6; }
.jc-cta-ico-contact { background: #f0f9ff; color: #0ea5e9; }

.jc-cta-title { font-size: .95rem; font-weight: 700; color: #111827; margin: 0; }
.jc-cta-desc  { font-size: .82rem; color: #6b7280; line-height: 1.55; margin: 0; flex: 1; }
.jc-cta-link  {
    font-size: .82rem; font-weight: 700; color: #2563eb;
    text-decoration: none; display: inline-flex; align-items: center; gap: 3px;
    margin-top: auto;
}
.jc-cta-link:hover { color: #1d4ed8; }

/* E-bülten */
.jc-newsletter {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 22px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
}
.jc-nl-label { font-size: .85rem; color: #374151; margin: 0; }
.jc-nl-form {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
}
.jc-nl-ico {
    padding: 0 12px;
    color: #9ca3af;
    display: flex; align-items: center;
    flex-shrink: 0;
}
.jc-nl-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: .88rem;
    padding: 12px 0;
    background: transparent;
    color: #111827;
}
.jc-nl-btn {
    flex-shrink: 0;
    background: #60a5fa;
    color: #fff;
    border: none;
    padding: 12px 20px;
    font-size: .85rem;
    font-weight: 700;
    cursor: pointer;
    display: flex; align-items: center; gap: 4px;
    transition: background .15s;
}
.jc-nl-btn:hover { background: #3b82f6; }
.jc-nl-note { font-size: .75rem; color: #9ca3af; margin: 0; }

@@media (max-width: 860px) {
    .jc-grid { grid-template-columns: 1fr; }
    .jc-bank-iban { word-break: break-all; }
}
@@media (max-width: 520px) {
    .jc-section { padding: 40px 16px; }
    .jc-cta-row { grid-template-columns: 1fr; }
    .jc-nl-form { flex-wrap: wrap; }
    .jc-nl-input { min-width: 0; flex: 1 1 100%; order: 2; padding: 12px; border-top: 1px solid #e5e7eb; }
    .jc-nl-ico { order: 1; padding: 10px 12px 0; }
    .jc-nl-btn { order: 3; flex: 1 1 100%; justify-content: center; border-radius: 0 0 8px 8px; }
    .jc-bank-row { gap: 8px; padding: 12px 14px; }
    .jc-bank-cur { min-width: 38px; }
}
</style>

<script>
(function () {
    document.querySelectorAll('.jc-copy-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var iban = btn.dataset.iban;
            navigator.clipboard.writeText(iban).then(function () {
                btn.classList.add('jc-copied');
                setTimeout(function () { btn.classList.remove('jc-copied'); }, 1500);
            });
        });
    });

    var nlBtn   = document.getElementById('jc-nl-btn');
    var nlEmail = document.getElementById('jc-nl-email');
    var nlNote  = document.getElementById('jc-nl-note');

    if (nlBtn && nlEmail) {
        function doSubscribe() {
            var email = nlEmail.value.trim();
            if (!email) return;
            nlBtn.disabled = true;

            var postData = { email: email, subscribe: true };
            addAntiForgeryToken(postData);

            $.ajax({
                cache: false,
                url: '/newsletter/SubscribeNewsletter',
                type: 'POST',
                data: postData,
                success: function (data) {
                    nlBtn.disabled = false;
                    if (data && data.Result) {
                        nlNote.textContent = data.Result;
                        nlNote.style.color = data.Success ? '#16a34a' : '#dc2626';
                    }
                    if (data && data.Success) nlEmail.value = '';
                },
                error: function () {
                    nlBtn.disabled = false;
                }
            });
        }

        nlBtn.addEventListener('click', doSubscribe);
        nlEmail.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') doSubscribe();
        });
    }
})();
</script>
