@model Nop.Plugin.Widgets.DonationCatalog.Models.DonationPageModel

<style>
    .don-section { padding: 30px 0; }

    .don-cats-wrap {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.08);
        padding: 24px 20px 20px;
        margin-bottom: 28px;
    }
    .don-cats-title {
        font-size: 11px; font-weight: 700; color: #aaa;
        text-transform: uppercase; letter-spacing: 1.5px;
        margin-bottom: 16px;
    }
    .don-cats { display: flex; gap: 12px; flex-wrap: wrap; }
    .don-cat-btn {
        display: flex; flex-direction: column; align-items: center; gap: 10px;
        padding: 16px 18px 14px;
        border: 2px solid #eee; border-radius: 12px;
        background: #fafafa; cursor: pointer;
        transition: all 0.2s; min-width: 90px;
    }
    .don-cat-btn:hover { border-color: #e43d51; background: #fff5f6; }
    .don-cat-btn.active {
        border-color: #e43d51; background: #fff0f2;
        box-shadow: 0 4px 14px rgba(228,61,81,0.15);
    }
    .don-cat-icon-wrap {
        width: 64px; height: 64px; border-radius: 10px;
        overflow: hidden; background: #f0f0f0;
        display: flex; align-items: center; justify-content: center;
        transition: box-shadow 0.2s;
    }
    .don-cat-btn.active .don-cat-icon-wrap,
    .don-cat-btn:hover .don-cat-icon-wrap { box-shadow: 0 4px 14px rgba(228,61,81,0.25); }
    .don-cat-icon-wrap img { width: 100%; height: 100%; object-fit: cover; }
    .don-cat-icon-wrap span { font-size: 26px; line-height: 1; }
    .don-cat-label {
        font-size: 12px; font-weight: 700; color: #555;
        text-align: center; line-height: 1.3;
        text-transform: uppercase; letter-spacing: 0.4px; max-width: 80px;
    }
    .don-cat-btn.active .don-cat-label { color: #e43d51; }

    .don-grid { display: none; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .don-grid.active { display: grid; }

    .don-card {
        border-radius: 12px; overflow: hidden;
        background: #fff; border: 1px solid #eee;
        transition: box-shadow 0.2s, transform 0.2s;
        display: flex; flex-direction: column;
    }
    .don-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.12); transform: translateY(-2px); }
    .don-card__img { position: relative; overflow: hidden; }
    .don-card__img img { width: 100%; height: 160px; object-fit: cover; display: block; transition: transform 0.35s; }
    .don-card:hover .don-card__img img { transform: scale(1.06); }
    .don-card__badge {
        position: absolute; top: 10px; left: 10px;
        background: #e43d51; color: #fff;
        font-size: 11px; font-weight: 700;
        padding: 3px 10px; border-radius: 20px;
        letter-spacing: 0.5px; text-transform: uppercase;
    }
    .don-card__body { padding: 10px 12px 0; flex: 1; }
    .don-card__title { font-size: 13px; font-weight: 700; color: #1a1a1a; line-height: 1.3; margin-bottom: 4px; }
    .don-card__desc {
        font-size: 12px; color: #999; line-height: 1.45;
        height: 34px; overflow: hidden;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }
    .don-card__footer {
        display: flex; align-items: center;
        padding: 8px 12px 12px; gap: 8px;
        border-top: 1px solid #f2f2f2; margin-top: 8px;
        flex-shrink: 0;
    }
    .don-card__price { font-size: 15px; font-weight: 800; color: #e43d51; white-space: nowrap; flex-shrink: 0; }
    .don-card__qty {
        display: flex; align-items: center;
        border: 1.5px solid #e0e0e0; border-radius: 6px;
        overflow: hidden; flex-shrink: 0;
    }
    .don-card__qty button {
        width: 26px; height: 28px; border: none;
        background: #f7f7f7; font-size: 16px; cursor: pointer;
        color: #555; transition: background 0.15s; line-height: 1;
    }
    .don-card__qty button:hover { background: #e43d51; color: #fff; }
    .don-card__qty-val {
        width: 30px; height: 28px;
        border-left: 1.5px solid #e0e0e0; border-right: 1.5px solid #e0e0e0;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 700; color: #222; background: #fff;
        user-select: none;
    }
    .don-card__btn {
        flex: 1; padding: 7px 8px;
        background: #e43d51; color: #fff; border: none;
        border-radius: 5px; font-size: 12px; font-weight: 700;
        cursor: pointer; text-transform: uppercase;
        letter-spacing: 0.5px; transition: background 0.2s; white-space: nowrap;
    }
    .don-card__btn:hover { background: #c4303f; }
    .don-card__btn:disabled { background: #ccc; cursor: not-allowed; }

    .don-toast {
        position: fixed; bottom: 24px; right: 24px; z-index: 9999;
        padding: 13px 22px; border-radius: 8px; font-size: 14px;
        font-weight: 600; display: none; box-shadow: 0 6px 20px rgba(0,0,0,0.18);
    }
    .don-toast.success { background: #2e7d32; color: #fff; }
    .don-toast.error   { background: #c62828; color: #fff; }

    @@media (max-width: 1199px) { .don-grid { grid-template-columns: repeat(3, 1fr); } }
    @@media (max-width: 991px)  { .don-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 767px)  {
        .don-cat-btn { min-width: 72px; padding: 12px 10px 10px; }
        .don-cat-icon-wrap { width: 52px; height: 52px; }
        .don-cat-label { font-size: 11px; }
    }
    @@media (max-width: 575px) {
        .don-grid { grid-template-columns: repeat(2, 1fr); }
        .don-cats { gap: 8px; }
    }
</style>

<div class="don-section">
    <div class="don-cats-wrap">
        <div class="don-cats-title">Bağış Kategorileri</div>
        <div class="don-cats">
            @for (var i = 0; i < Model.Categories.Count; i++)
            {
                var cat = Model.Categories[i];
                <button class="don-cat-btn @(i == 0 ? "active" : "")" data-cat="@cat.Id">
                    <div class="don-cat-icon-wrap">
                        @if (!string.IsNullOrEmpty(cat.IconUrl))
                        {
                            <img src="@cat.IconUrl" alt="@cat.Name" />
                        }
                        else
                        {
                            <span>🎁</span>
                        }
                    </div>
                    <span class="don-cat-label">@cat.Name</span>
                </button>
            }
        </div>
    </div>

    @for (var i = 0; i < Model.Categories.Count; i++)
    {
        var cat = Model.Categories[i];
        <div class="don-grid @(i == 0 ? "active" : "")" id="cat-@cat.Id">
            @foreach (var product in cat.Products)
            {
                <div class="don-card" onclick="if(!event.target.closest('.don-card__footer'))window.location.href='/@product.SeName'">
                    <div class="don-card__img">
                        @{ var pic = product.PictureModels.FirstOrDefault(); }
                        <img src="@(pic?.ImageUrl)"
                             alt="@(pic?.AlternateText ?? product.Name)"
                             title="@(pic?.Title ?? product.Name)"
                             loading="lazy" />
                    </div>
                    <div class="don-card__body">
                        <div class="don-card__title">@product.Name</div>
                        @if (!string.IsNullOrEmpty(product.ShortDescription))
                        {
                            <div class="don-card__desc">@product.ShortDescription</div>
                        }
                    </div>
                    <div class="don-card__footer">
                        <span class="don-card__price">@product.ProductPrice.Price</span>
                        <div class="don-card__qty">
                            <button type="button" class="qty-minus" aria-label="Azalt">−</button>
                            <span class="don-card__qty-val">1</span>
                            <input type="hidden" class="qty-input" value="1" />
                            <button type="button" class="qty-plus" aria-label="Artır">+</button>
                        </div>
                        <button type="button" class="don-card__btn" data-product-id="@product.Id">
                            Bağış Yap
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div id="don-toast" class="don-toast"></div>

<script>
(function () {
    document.querySelectorAll('.don-cat-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.don-cat-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.don-grid').forEach(g => g.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('cat-' + btn.dataset.cat).classList.add('active');
        });
    });

    document.querySelectorAll('.don-card').forEach(function (card) {
        card.style.cursor = 'pointer';
        var input = card.querySelector('.qty-input');
        var display = card.querySelector('.don-card__qty-val');
        card.querySelector('.qty-minus').addEventListener('click', function () {
            var val = parseInt(input.value) || 1;
            if (val > 1) { input.value = val - 1; display.textContent = val - 1; }
        });
        card.querySelector('.qty-plus').addEventListener('click', function () {
            var val = parseInt(input.value) || 1;
            input.value = val + 1; display.textContent = val + 1;
        });
    });

    document.querySelectorAll('.don-card__btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var card = btn.closest('.don-card');
            var productId = btn.dataset.productId;
            var qty = parseInt(card.querySelector('.qty-input').value) || 1;
            btn.disabled = true;
            AjaxCart.addproducttocart_catalog('/addproducttocart/catalog/' + productId + '/1/' + qty);
            setTimeout(function () { btn.disabled = false; }, 1500);
        });
    });
})();
</script>
