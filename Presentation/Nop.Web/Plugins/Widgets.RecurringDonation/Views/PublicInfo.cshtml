@model Nop.Plugin.Widgets.RecurringDonation.Models.PublicInfoModel
@{ Layout = ""; }

<section class="recurring-section">
    <div class="recurring-inner">
        <div class="recurring-left">
            <div class="recurring-icon">🔄</div>
            <h2 class="recurring-title">@Model.Title</h2>
            <p class="recurring-subtitle">@Model.Subtitle</p>
        </div>
        <div class="recurring-right">
            <div class="recurring-amounts">
                @foreach (var amount in Model.Amounts)
                {
                    var url = string.IsNullOrEmpty(amount.Url) ? "#" : amount.Url;
                    <a href="@url" class="recurring-btn">@amount.Label</a>
                }
            </div>
            @if (!string.IsNullOrEmpty(Model.CustomAmountUrl))
            {
                <a href="@Model.CustomAmountUrl" class="recurring-custom">
                    ✏️ Kendi tutarımı belirleyeyim
                </a>
            }
        </div>
    </div>
</section>

<style>
    .recurring-section {
        padding: 48px 0;
        background: linear-gradient(135deg, #f8f9ff 0%, #fff5f6 100%);
        border-top: 1px solid #f0f0f0;
        border-bottom: 1px solid #f0f0f0;
    }
    .recurring-inner {
        display: flex; align-items: center; gap: 48px;
        max-width: 900px; margin: 0 auto; padding: 0 24px;
    }
    .recurring-left { flex: 1; }
    .recurring-right { flex: 1; }

    .recurring-icon { font-size: 40px; margin-bottom: 12px; line-height: 1; }
    .recurring-title {
        font-size: 26px; font-weight: 900;
        color: #1a1a1a; margin: 0 0 12px; line-height: 1.2;
    }
    .recurring-subtitle {
        font-size: 14px; color: #666;
        line-height: 1.65; margin: 0;
    }

    .recurring-amounts {
        display: grid; grid-template-columns: repeat(2, 1fr);
        gap: 12px; margin-bottom: 14px;
    }
    .recurring-btn {
        display: flex; align-items: center; justify-content: center;
        padding: 14px 16px;
        border: 2px solid #e43d51; border-radius: 10px;
        color: #e43d51; font-size: 15px; font-weight: 800;
        text-decoration: none;
        transition: all 0.2s;
    }
    .recurring-btn:hover {
        background: #e43d51; color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(228,61,81,0.3);
    }
    .recurring-custom {
        display: block; text-align: center;
        font-size: 13px; font-weight: 600; color: #888;
        text-decoration: none; padding: 8px;
        transition: color 0.2s;
    }
    .recurring-custom:hover { color: #e43d51; }

    @@media (max-width: 767px) {
        .recurring-inner { flex-direction: column; gap: 28px; }
        .recurring-title { font-size: 22px; }
    }
</style>
