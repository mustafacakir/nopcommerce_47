@model Nop.Plugin.Widgets.TrustBadges.Models.ConfigurationModel
@{ Layout = "_ConfigurePlugin"; }

@await Component.InvokeAsync("StoreScopeConfiguration")
<form asp-controller="WidgetsTrustBadges" asp-action="Configure" method="post">
    <div class="panel-group">
        @foreach (var i in new[] { 1, 2, 3, 4, 5 })
        {
            <div class="panel panel-default">
                <div class="panel-heading">Rozet @i</div>
                <div class="panel-body">
                    <div class="form-group row">
                        <div class="col-md-3"><label>İkon (emoji)</label></div>
                        <div class="col-md-9"><input type="text" name="Badge@(i)Icon" value="@(i == 1 ? Model.Badge1Icon : i == 2 ? Model.Badge2Icon : i == 3 ? Model.Badge3Icon : i == 4 ? Model.Badge4Icon : Model.Badge5Icon)" class="form-control" /></div>
                    </div>
                    <div class="form-group row">
                        <div class="col-md-3"><label>Başlık</label></div>
                        <div class="col-md-9"><input type="text" name="Badge@(i)Title" value="@(i == 1 ? Model.Badge1Title : i == 2 ? Model.Badge2Title : i == 3 ? Model.Badge3Title : i == 4 ? Model.Badge4Title : Model.Badge5Title)" class="form-control" /></div>
                    </div>
                    <div class="form-group row">
                        <div class="col-md-3"><label>Alt Metin</label></div>
                        <div class="col-md-9"><input type="text" name="Badge@(i)Subtitle" value="@(i == 1 ? Model.Badge1Subtitle : i == 2 ? Model.Badge2Subtitle : i == 3 ? Model.Badge3Subtitle : i == 4 ? Model.Badge4Subtitle : Model.Badge5Subtitle)" class="form-control" /></div>
                    </div>
                </div>
            </div>
        }
        <div class="panel panel-default">
            <div class="panel-body">
                <div class="form-group row">
                    <div class="col-md-9 col-md-offset-3">
                        <input type="submit" name="save" class="btn bg-blue" value="@T("Admin.Common.Save")" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
