@model Nop.Plugin.Widgets.TrustBadges.Models.PublicInfoModel
@{ Layout = ""; }

@if (Model.Badges.Any())
{
    <section class="trust-section">
        <div class="trust-inner">
            @foreach (var badge in Model.Badges)
            {
                <div class="trust-item">
                    <span class="trust-icon">@badge.Icon</span>
                    <div class="trust-text">
                        <strong>@badge.Title</strong>
                        <span>@badge.Subtitle</span>
                    </div>
                </div>
            }
        </div>
    </section>
}

<style>
    .trust-section {
        background: #fff;
        border-top: 1px solid #f0f0f0;
        border-bottom: 1px solid #f0f0f0;
        padding: 24px 0;
    }
    .trust-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        justify-content: space-around;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
    }
    .trust-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 16px;
    }
    .trust-icon { font-size: 28px; line-height: 1; flex-shrink: 0; }
    .trust-text {
        display: flex;
        flex-direction: column;
    }
    .trust-text strong {
        font-size: 13px;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1.3;
    }
    .trust-text span {
        font-size: 11px;
        color: #888;
        line-height: 1.3;
    }

    @@media (max-width: 767px) {
        .trust-inner { justify-content: flex-start; }
        .trust-item { flex: 0 0 calc(50% - 16px); }
    }
</style>
