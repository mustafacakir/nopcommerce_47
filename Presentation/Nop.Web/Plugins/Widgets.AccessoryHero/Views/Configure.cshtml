@model Nop.Plugin.Widgets.AccessoryHero.Models.ConfigurationModel
@{
    Layout = "_ConfigurePlugin";
}

@await Component.InvokeAsync("StoreScopeConfiguration")
<form asp-controller="WidgetsAccessoryHero" asp-action="Configure" method="post">
    <div class="panel-group">
        <div class="panel panel-default">
            <div class="panel-heading">Accessory Hero Ayarları</div>
            <div class="panel-body">

                @foreach (var field in new[] {
                    ("BadgeText",    "Rozet Metni"),
                    ("TitleLine1",   "Başlık — 1. Satır (koyu)"),
                    ("TitleAccent",  "Başlık — Vurgulu Satır (turuncu)"),
                    ("TitleLine2",   "Başlık — 3. Satır (koyu)"),
                    ("Description",  "Açıklama Metni"),
                    ("Button1Text",  "1. Buton Metni"),
                    ("Button1Url",   "1. Buton Linki"),
                    ("Button2Text",  "2. Buton Metni"),
                    ("Button2Url",   "2. Buton Linki"),
                    ("Image1Url",    "Mozaik Görsel 1 URL"),
                    ("Image2Url",    "Mozaik Görsel 2 URL"),
                    ("Image3Url",    "Mozaik Görsel 3 URL"),
                    ("Image4Url",    "Mozaik Görsel 4 URL"),
                })
                {
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label>@field.Item2</label>
                        </div>
                        <div class="col-md-9">
                            <input type="text" name="@field.Item1"
                                   value="@(Model.GetType().GetProperty(field.Item1)?.GetValue(Model))"
                                   class="form-control" />
                        </div>
                    </div>
                }

            </div>
        </div>
        <div class="panel panel-default">
            <div class="panel-body">
                <div class="form-group row">
                    <div class="col-md-9 col-md-offset-3">
                        <input type="submit" name="save" class="btn bg-blue" value="@T("Admin.Common.Save")" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
