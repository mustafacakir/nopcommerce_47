@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = "Abonelik";

    var status       = (string)ViewBag.Status;
    var trialEndDate = (string)ViewBag.TrialEndDate;
    var daysRemaining = (int?)ViewBag.DaysRemaining;
    var subEndDate   = (string)ViewBag.SubEndDate;
    var currentPlan  = (string)ViewBag.Plan;
    var plans        = (Dictionary<string, (string Label, decimal Price, int Months)>)ViewBag.Plans;

    var result = Context.Request.Query["result"].ToString();
}

<div class="content-header clearfix">
    <h1 class="float-left">Abonelik</h1>
</div>

<div class="content">
    @if (result == "success")
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            <i class="fas fa-check-circle"></i> <strong>Ödeme alındı!</strong> Aboneliğiniz başarıyla aktifleştirildi.
        </div>
    }
    @if (result == "fail")
    {
        <div class="alert alert-danger alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            <i class="fas fa-times-circle"></i> <strong>Ödeme başarısız.</strong> Lütfen tekrar deneyin.
        </div>
    }

    @if (status == "active")
    {
        <div class="card card-default">
            <div class="card-body">
                <div class="alert alert-success mb-0">
                    <i class="fas fa-check-circle"></i>
                    <strong>Aktif Abonelik</strong> — @(currentPlan == "1y" ? "1 Yıllık" : currentPlan == "2y" ? "2 Yıllık" : "3 Yıllık") plan
                    @if (!string.IsNullOrEmpty(subEndDate))
                    {
                        <span> · <b>@subEndDate</b> tarihine kadar geçerli</span>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Durum Banner -->
        <div class="card card-default">
            <div class="card-body">
                @if (daysRemaining > 0)
                {
                    <div class="alert alert-warning mb-0">
                        <i class="fas fa-clock"></i>
                        Deneme süreniz <strong>@trialEndDate</strong> tarihinde sona eriyor.
                        <strong>@daysRemaining gün</strong> kaldı.
                    </div>
                }
                else
                {
                    <div class="alert alert-danger mb-0">
                        <i class="fas fa-exclamation-triangle"></i>
                        Deneme süreniz doldu. Mağazanıza erişmeye devam etmek için bir plan seçin.
                    </div>
                }
            </div>
        </div>

        <!-- Plan Seçimi -->
        <div class="card card-default" id="plan-section">
            <div class="card-header">
                <h5 class="card-title">Plan Seçin</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (var p in plans)
                    {
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 text-center" style="border: 2px solid #dee2e6; border-radius: 8px;">
                                <div class="card-body d-flex flex-column justify-content-between">
                                    <div>
                                        <h5 class="font-weight-bold">@p.Value.Label</h5>
                                        <h2 class="text-primary font-weight-bold">₺@p.Value.Price.ToString("N0")</h2>
                                        <p class="text-muted">@p.Value.Months ay erişim</p>
                                    </div>
                                    <button class="btn btn-primary btn-block mt-3 plan-btn"
                                            data-plan="@p.Key">
                                        Seç ve Öde
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- iyzico Ödeme Formu -->
        <div class="card card-default d-none" id="checkout-card">
            <div class="card-header">
                <h5 class="card-title">Ödeme Bilgileri</h5>
                <button class="btn btn-sm btn-secondary float-right" id="back-btn">Geri</button>
            </div>
            <div class="card-body">
                <div id="iyzico-checkout-form"></div>
            </div>
        </div>
    }
</div>

<script>
    document.querySelectorAll('.plan-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var plan = this.getAttribute('data-plan');
                var originalText = this.textContent;
                this.textContent = 'Yükleniyor...';
                this.disabled = true;

                fetch('@Url.Action("Checkout", "Subscription", new { area = "Admin" })?plan=' + plan, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' }
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (!data.success) {
                        alert(data.message || 'Ödeme formu oluşturulamadı.');
                        btn.textContent = originalText;
                        btn.disabled = false;
                        return;
                    }
                    // Plan bölümünü gizle, checkout formunu göster
                    document.getElementById('plan-section').classList.add('d-none');
                    document.getElementById('checkout-card').classList.remove('d-none');

                    // iyzico HTML'ini inject et
                    var container = document.getElementById('iyzico-checkout-form');
                    container.innerHTML = data.checkoutFormContent;
                    container.querySelectorAll('script').forEach(function(old) {
                        var s = document.createElement('script');
                        if (old.src) s.src = old.src; else s.textContent = old.textContent;
                        document.body.appendChild(s);
                    });
                })
                .catch(function() {
                    alert('Sunucuya bağlanılamadı.');
                    btn.textContent = originalText;
                    btn.disabled = false;
                });
            });
        });

        document.getElementById('back-btn')?.addEventListener('click', function() {
            document.getElementById('plan-section').classList.remove('d-none');
            document.getElementById('checkout-card').classList.add('d-none');
            document.getElementById('iyzico-checkout-form').innerHTML = '';
        });
</script>
