@model ContactUsModel
@{
    Layout = "_ColumnsOne";
    NopHtml.AddTitleParts(T("PageTitle.ContactUs").Text);
    NopHtml.AppendPageCssClassParts("html-contact-page");
}

<div class="page contact-page">
    <div class="page-title">
        <h1>@T("PageTitle.ContactUs")</h1>
    </div>
    <div class="page-body">
        @await Component.InvokeAsync(typeof(TopicBlockViewComponent), new { systemName = "ContactUs" })
        @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.ContactUsTop, additionalData = Model })

        @if (Model.SuccessfullySent)
        {
            <div class="cu-success">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
                <p>@Model.Result</p>
            </div>
        }
        else
        {
            <div class="cu-form-wrap">
                <div class="cu-form-header">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    <span>Mesaj Gönderin</span>
                </div>
                <form asp-route="ContactUs" method="post" class="cu-form">
                    <div asp-validation-summary="ModelOnly" class="cu-error"></div>

                    <div class="cu-row">
                        <div class="cu-field">
                            <label asp-for="FullName">Ad Soyad <span class="cu-req">*</span></label>
                            <input asp-for="FullName" placeholder="@T("ContactUs.FullName.Hint")" class="cu-input" />
                            <span asp-validation-for="FullName" class="cu-val"></span>
                        </div>
                        <div class="cu-field">
                            <label asp-for="Email">E-posta <span class="cu-req">*</span></label>
                            <input asp-for="Email" placeholder="@T("ContactUs.Email.Hint")" class="cu-input" />
                            <span asp-validation-for="Email" class="cu-val"></span>
                        </div>
                    </div>

                    @if (Model.SubjectEnabled)
                    {
                        <div class="cu-field">
                            <label asp-for="Subject">Konu <span class="cu-req">*</span></label>
                            <input asp-for="Subject" placeholder="@T("ContactUs.Subject.Hint")" class="cu-input" />
                            <span asp-validation-for="Subject" class="cu-val"></span>
                        </div>
                    }

                    <div class="cu-field">
                        <label asp-for="Enquiry">Mesajınız <span class="cu-req">*</span></label>
                        <textarea asp-for="Enquiry" placeholder="@T("ContactUs.Enquiry.Hint")" class="cu-input cu-textarea" rows="5"></textarea>
                        <span asp-validation-for="Enquiry" class="cu-val"></span>
                    </div>

                    @if (Model.DisplayCaptcha)
                    {
                        <div class="cu-field">
                            <nop-captcha />
                        </div>
                    }

                    <button type="submit" name="send-email" class="cu-submit">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                        @T("ContactUs.Button")
                    </button>
                </form>
            </div>
        }

        @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.ContactUsBottom, additionalData = Model })
    </div>
</div>

<style>
.cu-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 48px 20px;
    text-align: center;
    color: #16a34a;
    font-weight: 600;
    font-size: 1rem;
}

.cu-form-wrap {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
    max-width: 720px;
    margin: 0 auto;
}

.cu-form-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 20px 28px;
    background: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
    font-size: 1rem;
    font-weight: 700;
    color: #111827;
}

.cu-form { padding: 28px; display: flex; flex-direction: column; gap: 20px; }

.cu-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

.cu-field { display: flex; flex-direction: column; gap: 6px; }

.cu-field label {
    font-size: .83rem;
    font-weight: 600;
    color: #374151;
}

.cu-req { color: #ef4444; }

.cu-input {
    width: 100%;
    padding: 11px 14px;
    border: 1.5px solid #e5e7eb;
    border-radius: 9px;
    font-size: .9rem;
    color: #111827;
    background: #fff;
    transition: border-color .15s, box-shadow .15s;
    box-sizing: border-box;
    font-family: inherit;
}
.cu-input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59,130,246,.12);
}
.cu-textarea { resize: vertical; min-height: 120px; }

.cu-val { font-size: .78rem; color: #ef4444; }

.cu-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: .85rem;
    color: #dc2626;
}

.cu-submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 12px 28px;
    font-size: .9rem;
    font-weight: 700;
    cursor: pointer;
    transition: background .15s;
}
.cu-submit:hover { background: #1d4ed8; }

@@media (max-width: 560px) {
    .cu-row { grid-template-columns: 1fr; }
    .cu-form { padding: 20px 16px; }
    .cu-submit { width: 100%; justify-content: center; }
}
</style>
