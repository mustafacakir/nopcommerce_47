    { "id": 700, "type": "row", "title": "📝 Loki — Uygulama Logları", "gridPos": { "x": 0, "y": 115, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 701, "type": "timeseries", "title": "Log Hacmi (Seviyeye Göre)",
