      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum(rate({job=\"nopcommerce\"} |= \"\" [5m])) by (level)", "legendFormat": "{{level}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 702, "type": "timeseries", "title": "Error / Warning Log Hızı",
      "gridPos": { "x": 12, "y": 116, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum(rate({job=\"nopcommerce\"} |~ \"(?i)error\" [5m]))", "legendFormat": "Error", "refId": "A" },
        { "expr": "sum(rate({job=\"nopcommerce\"} |~ \"(?i)warn\" [5m]))", "legendFormat": "Warning", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "Warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
      ]}
    },
