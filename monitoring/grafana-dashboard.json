{
  "title": "nopCommerce — Production Monitor",
  "uid": "nopcommerce-main",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "store",
        "type": "query",
        "label": "Mağaza",
        "datasource": { "type": "prometheus", "uid": "afhxt0ru7zqiof" },
        "query": "label_values(store_requests_total, store_name)",
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [

    { "id": 900, "type": "row", "title": "🔴 Genel Sağlık", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 901, "type": "gauge", "title": "CPU Kullanımı",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 5 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true, "showThresholdLabels": false },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 85 }] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 902, "type": "gauge", "title": "RAM Kullanımı",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 5 },
      "targets": [{ "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 903, "type": "gauge", "title": "Disk Kullanımı",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 5 },
      "targets": [{ "expr": "100 * (1 - min(node_filesystem_free_bytes{fstype!~\"tmpfs|overlay\",mountpoint=\"/\"}) / min(node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\",mountpoint=\"/\"}))", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 904, "type": "stat", "title": "Aktif Container",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 5 },
      "targets": [{ "expr": "count(count by (name) (container_last_seen{name!=\"\"}))", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 905, "type": "stat", "title": "HTTP Hata Oranı",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 5 },
      "targets": [{ "expr": "100 * sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\", http_response_status_code=~\"[45]..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\"}[5m])) or vector(0)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 906, "type": "stat", "title": "Ort. Yanıt (p95)",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 5 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"nopcommerce\"}[5m])) by (le))", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "noValue": "—" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] } } }
    },

    { "id": 100, "type": "row", "title": "📊 Mağaza Metrikleri", "gridPos": { "x": 0, "y": 6, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 101, "type": "stat", "title": "Toplam İstek",
      "gridPos": { "x": 0, "y": 7, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(store_requests_total{store_name=~\"$store\"}) or vector(0)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 102, "type": "stat", "title": "İstek/Saniye",
      "gridPos": { "x": 6, "y": 7, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(store_requests_total{store_name=~\"$store\"}[5m])) or vector(0)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 103, "type": "stat", "title": "Hata Sayısı (4xx+5xx)",
      "gridPos": { "x": 12, "y": 7, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(store_errors_total{store_name=~\"$store\"}) or vector(0)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } } }
    },
    {
      "id": 104, "type": "stat", "title": "Ort. Yanıt Süresi",
      "gridPos": { "x": 18, "y": 7, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(store_request_duration_ms_sum{store_name=~\"$store\"}[5m])) / sum(rate(store_request_duration_ms_count{store_name=~\"$store\"}[5m]))", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "noValue": "—" },
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } } }
    },
    {
      "id": 105, "type": "timeseries", "title": "Mağaza Bazında İstek Hızı",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum(rate(store_requests_total{store_name=~\"$store\"}[5m])) by (store_name)", "legendFormat": "{{store_name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 106, "type": "timeseries", "title": "Mağaza Bazında Yanıt Süresi (p95)",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(store_request_duration_ms_bucket{store_name=~\"$store\"}[5m])) by (le, store_name))", "legendFormat": "{{store_name}} p95", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 107, "type": "table", "title": "Mağaza Karşılaştırma",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 6 },
      "targets": [
        { "expr": "sum(rate(store_requests_total[5m])) by (store_id, store_name)", "refId": "A", "instant": true, "format": "table" },
        { "expr": "sum(rate(store_errors_total[5m])) by (store_id, store_name)", "refId": "B", "instant": true, "format": "table" },
        { "expr": "sum(rate(store_request_duration_ms_sum[5m])) by (store_id, store_name) / sum(rate(store_request_duration_ms_count[5m])) by (store_id, store_name)", "refId": "C", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "store_name": "Mağaza", "store_id": "ID", "Value #A": "İstek/s", "Value #B": "Hata/s", "Value #C": "Ort. ms" }, "excludeByName": { "Time": true } } }
      ],
      "options": { "sortBy": [{ "displayName": "İstek/s", "desc": true }] },
      "fieldConfig": { "defaults": { "decimals": 3 }, "overrides": [{ "matcher": { "id": "byName", "options": "Ort. ms" }, "properties": [{ "id": "unit", "value": "ms" }] }] }
    },
    {
      "id": 108, "type": "table", "title": "En Çok İstenen URL'ler (Top 20)",
      "gridPos": { "x": 0, "y": 25, "w": 14, "h": 10 },
      "targets": [
        { "expr": "sort_desc(topk(20, sum(rate(store_requests_total{store_name=~\"$store\"}[10m])) by (method, path)))", "refId": "A", "instant": true, "format": "table" },
        { "expr": "topk(20, sum(rate(store_request_duration_ms_sum{store_name=~\"$store\"}[10m])) by (method, path) / sum(rate(store_request_duration_ms_count{store_name=~\"$store\"}[10m])) by (method, path))", "refId": "B", "instant": true, "format": "table" },
        { "expr": "topk(20, sum(rate(store_errors_total{store_name=~\"$store\"}[10m])) by (method, path))", "refId": "C", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "method": "Method", "path": "URL", "Value #A": "İstek/s", "Value #B": "Ort. ms", "Value #C": "Hata/s" }, "excludeByName": { "Time": true } } }
      ],
      "options": { "sortBy": [{ "displayName": "İstek/s", "desc": true }] },
      "fieldConfig": { "defaults": { "decimals": 3 }, "overrides": [
        { "matcher": { "id": "byName", "options": "Ort. ms" }, "properties": [{ "id": "unit", "value": "ms" }] },
        { "matcher": { "id": "byName", "options": "Hata/s" }, "properties": [{ "id": "custom.displayMode", "value": "color-text" }, { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } }, { "id": "color", "value": { "mode": "thresholds" } }] }
      ]}
    },
    {
      "id": 109, "type": "table", "title": "En Yavaş URL'ler (Top 10)",
      "gridPos": { "x": 14, "y": 25, "w": 10, "h": 10 },
      "targets": [{ "expr": "sort_desc(topk(10, sum(rate(store_request_duration_ms_sum{store_name=~\"$store\"}[10m])) by (method, path) / sum(rate(store_request_duration_ms_count{store_name=~\"$store\"}[10m])) by (method, path)))", "refId": "A", "instant": true, "format": "table" }],
      "transformations": [{ "id": "organize", "options": { "renameByName": { "method": "Method", "path": "URL", "Value": "Ort. ms" }, "excludeByName": { "Time": true } } }],
      "options": { "sortBy": [{ "displayName": "Ort. ms", "desc": true }] },
      "fieldConfig": { "defaults": { "decimals": 1 }, "overrides": [{ "matcher": { "id": "byName", "options": "Ort. ms" }, "properties": [{ "id": "unit", "value": "ms" }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } }, { "id": "color", "value": { "mode": "thresholds" } }] }] }
    },

    { "id": 200, "type": "row", "title": "🌐 API & HTTP Metrikleri", "gridPos": { "x": 0, "y": 35, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 201, "type": "stat", "title": "Toplam İstek (ASP.NET)",
      "gridPos": { "x": 0, "y": 36, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(http_server_request_duration_seconds_count{job=\"nopcommerce\"}) or vector(0)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 202, "type": "stat", "title": "İstek/s (ASP.NET)",
      "gridPos": { "x": 6, "y": 36, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\"}[5m])) or vector(0)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 203, "type": "stat", "title": "5xx Hata/s",
      "gridPos": { "x": 12, "y": 36, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\", http_response_status_code=~\"5..\"}[5m])) or vector(0)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "decimals": 3, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.1 }] } } }
    },
    {
      "id": 204, "type": "stat", "title": "Aktif HTTP İsteği",
      "gridPos": { "x": 18, "y": 36, "w": 6, "h": 4 },
      "targets": [{ "expr": "http_server_active_requests{job=\"nopcommerce\"} or vector(0)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } } }
    },
    {
      "id": 205, "type": "timeseries", "title": "İstek Hızı — Durum Koduna Göre",
      "gridPos": { "x": 0, "y": 40, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\"}[5m]))", "legendFormat": "Toplam", "refId": "A" },
        { "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\", http_response_status_code=~\"2..\"}[5m]))", "legendFormat": "2xx", "refId": "B" },
        { "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\", http_response_status_code=~\"3..\"}[5m]))", "legendFormat": "3xx", "refId": "C" },
        { "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\", http_response_status_code=~\"4..\"}[5m]))", "legendFormat": "4xx", "refId": "D" },
        { "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\", http_response_status_code=~\"5..\"}[5m]))", "legendFormat": "5xx", "refId": "E" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [
        { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
      ]}
    },
    {
      "id": 206, "type": "timeseries", "title": "Yanıt Süresi — p50 / p95 / p99",
      "gridPos": { "x": 12, "y": 40, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=\"nopcommerce\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"nopcommerce\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=\"nopcommerce\"}[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 207, "type": "timeseries", "title": "Hata Oranı % (4xx + 5xx)",
      "gridPos": { "x": 0, "y": 48, "w": 12, "h": 8 },
      "targets": [
        { "expr": "100 * sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\", http_response_status_code=~\"4..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\"}[5m])) or vector(0)", "legendFormat": "4xx %", "refId": "A" },
        { "expr": "100 * sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\", http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{job=\"nopcommerce\"}[5m])) or vector(0)", "legendFormat": "5xx %", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2 } }, "overrides": [
        { "matcher": { "id": "byName", "options": "4xx %" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "5xx %" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
      ]}
    },
    {
      "id": 208, "type": "timeseries", "title": "URL Bazında İstek Hızı (Top 10)",
      "gridPos": { "x": 12, "y": 48, "w": 12, "h": 8 },
      "targets": [{ "expr": "topk(10, sum(rate(store_requests_total{store_name=~\"$store\"}[5m])) by (path))", "legendFormat": "{{path}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },

    { "id": 500, "type": "row", "title": "🐳 Docker Container Health", "gridPos": { "x": 0, "y": 56, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 501, "type": "table", "title": "Container Durumu",
      "gridPos": { "x": 0, "y": 57, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name!=\"\"}[2m])) by (name) * 100",
          "refId": "A", "instant": true, "format": "table", "legendFormat": ""
        },
        {
          "expr": "container_memory_usage_bytes{name!=\"\"} / 1024 / 1024",
          "refId": "B", "instant": true, "format": "table", "legendFormat": ""
        },
        {
          "expr": "time() - container_last_seen{name!=\"\"}",
          "refId": "C", "instant": true, "format": "table", "legendFormat": ""
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": {
          "renameByName": { "name": "Container", "Value #A": "CPU %", "Value #B": "RAM (MB)", "Value #C": "Son Görülme (s)" },
          "excludeByName": { "Time": true }
        }}
      ],
      "options": { "sortBy": [{ "displayName": "CPU %", "desc": true }] },
      "fieldConfig": {
        "defaults": { "decimals": 2 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CPU %" }, "properties": [
            { "id": "unit", "value": "percent" },
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] } },
            { "id": "color", "value": { "mode": "thresholds" } }
          ]},
          { "matcher": { "id": "byName", "options": "RAM (MB)" }, "properties": [{ "id": "unit", "value": "decmbytes" }] },
          { "matcher": { "id": "byName", "options": "Son Görülme (s)" }, "properties": [
            { "id": "custom.displayMode", "value": "color-text" },
            { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 60 }] } },
            { "id": "color", "value": { "mode": "thresholds" } }
          ]}
        ]
      }
    },
    {
      "id": 502, "type": "timeseries", "title": "Container CPU Kullanımı %",
      "gridPos": { "x": 12, "y": 57, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{name!=\"\"}[2m])) by (name) * 100", "legendFormat": "{{name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 503, "type": "timeseries", "title": "Container RAM Kullanımı",
      "gridPos": { "x": 0, "y": 65, "w": 12, "h": 8 },
      "targets": [{ "expr": "container_memory_usage_bytes{name!=\"\"}", "legendFormat": "{{name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 504, "type": "timeseries", "title": "Container Ağ I/O",
      "gridPos": { "x": 12, "y": 65, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(container_network_receive_bytes_total{name!=\"\"}[5m])) by (name)", "legendFormat": "↓ {{name}}", "refId": "A" },
