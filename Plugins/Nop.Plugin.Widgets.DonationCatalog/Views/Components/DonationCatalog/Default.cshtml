@model Nop.Plugin.Widgets.DonationCatalog.Models.DonationPageModel

@{
    var icons = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Zekat-Sadaka"]  = "🤲",
        ["Aşevi"]         = "🍲",
        ["Kurban"]        = "🐑",
        ["Su Kuyusu"]     = "💧",
        ["Kuran-ı Kerim"] = "📖",
        ["Yemek İkramı"]  = "🍽️",
    };

    var groupIcons = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Yurtiçi Faaliyetleri"]  = "🇹🇷",
        ["Yurtdışı Faaliyetleri"] = "🌍",
    };

    var subCategories = Model.Categories
        .Where(c => !string.IsNullOrEmpty(c.ParentCategoryName))
        .ToList();

    if (!subCategories.Any())
        subCategories = Model.Categories.ToList();
}

<section class="dc-section">
    <div class="dc-container">

        <header class="dc-hero">
            <div class="dc-hero__badge">Bağış Yap</div>
            <h1 class="dc-hero__title">Her Bağış Bir Umut Işığı</h1>
            <p class="dc-hero__sub">İhtiyaç sahiplerine ulaştırmak için doğru yerdesiniz. Kategoriyi seçin, miktarı belirleyin, bağışınızı yapın.</p>
        </header>

        <div class="dc-tabs" role="tablist">
            <button class="dc-tab active" data-cat="all" type="button" role="tab" aria-selected="true">
                <span class="dc-tab__icon">🌟</span>
                <span class="dc-tab__label">Tümü</span>
                <span class="dc-tab__count">@subCategories.Sum(c => c.Products.Count)</span>
            </button>
            @for (var i = 0; i < subCategories.Count; i++)
            {
                var cat = subCategories[i];
                icons.TryGetValue(cat.Name, out var icon);
                <button class="dc-tab"
                        data-cat="@cat.Id"
                        type="button"
                        role="tab"
                        aria-selected="false">
                    <span class="dc-tab__icon">
                        @if (!string.IsNullOrEmpty(cat.IconUrl))
                        {
                            <img src="@cat.IconUrl" alt="" />
                        }
                        else
                        {
                            @(string.IsNullOrEmpty(icon) ? "🎁" : icon)
                        }
                    </span>
                    <span class="dc-tab__label">@cat.Name</span>
                    <span class="dc-tab__count">@cat.Products.Count</span>
                </button>
            }
        </div>

        @{
            var allProducts = subCategories.SelectMany(c => c.Products).ToList();
        }

        <div class="dc-grid active" id="cat-all" role="tabpanel">
            @foreach (var product in allProducts)
            {
                var pic = product.PictureModels.FirstOrDefault();
                <article class="dc-card" data-href="/@product.SeName">
                    <div class="dc-card__media">
                        @if (!string.IsNullOrEmpty(pic?.ImageUrl))
                        {
                            <img src="@pic.ImageUrl" alt="@(pic.AlternateText ?? product.Name)" loading="lazy" />
                        }
                        else
                        {
                            <div class="dc-card__placeholder">🎁</div>
                        }
                        <div class="dc-card__overlay"></div>
                        <div class="dc-card__price-badge">@product.ProductPrice.Price</div>
                    </div>
                    <div class="dc-card__body">
                        <h3 class="dc-card__title">@product.Name</h3>
                        @if (!string.IsNullOrEmpty(product.ShortDescription))
                        {
                            <p class="dc-card__desc">@product.ShortDescription</p>
                        }
                    </div>
                    <div class="dc-card__footer">
                        <div class="dc-card__qty">
                            <button type="button" class="qty-minus" aria-label="Azalt">−</button>
                            <span class="dc-card__qty-val">1</span>
                            <input type="hidden" class="qty-input" value="1" />
                            <button type="button" class="qty-plus" aria-label="Artır">+</button>
                        </div>
                        <button type="button" class="dc-card__btn" data-product-id="@product.Id">
                            <span class="dc-card__btn-icon">🤲</span>
                            Bağış Yap
                        </button>
                    </div>
                </article>
            }
        </div>

        @foreach (var cat in subCategories)
        {
            <div class="dc-grid" id="cat-@cat.Id" role="tabpanel">
                @foreach (var product in cat.Products)
                {
                    var pic = product.PictureModels.FirstOrDefault();
                    <article class="dc-card" data-href="/@product.SeName">
                        <div class="dc-card__media">
                            @if (!string.IsNullOrEmpty(pic?.ImageUrl))
                            {
                                <img src="@pic.ImageUrl" alt="@(pic.AlternateText ?? product.Name)" loading="lazy" />
                            }
                            else
                            {
                                <div class="dc-card__placeholder">🎁</div>
                            }
                            <div class="dc-card__overlay"></div>
                            <div class="dc-card__price-badge">@product.ProductPrice.Price</div>
                        </div>
                        <div class="dc-card__body">
                            <h3 class="dc-card__title">@product.Name</h3>
                            @if (!string.IsNullOrEmpty(product.ShortDescription))
                            {
                                <p class="dc-card__desc">@product.ShortDescription</p>
                            }
                        </div>
                        <div class="dc-card__footer">
                            <div class="dc-card__qty">
                                <button type="button" class="qty-minus" aria-label="Azalt">−</button>
                                <span class="dc-card__qty-val">1</span>
                                <input type="hidden" class="qty-input" value="1" />
                                <button type="button" class="qty-plus" aria-label="Artır">+</button>
                            </div>
                            <button type="button" class="dc-card__btn" data-product-id="@product.Id">
                                <span class="dc-card__btn-icon">🤲</span>
                                Bağış Yap
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>

<div id="dc-toast" class="dc-toast" role="alert"></div>

<style>
    /* ── Base ── */
    .dc-section {
        background: #f4f6fb;
        padding: 56px 0 72px;
    }
    .dc-container {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 24px;
    }

    /* ── Hero ── */
    .dc-hero {
        text-align: center;
        margin-bottom: 56px;
    }
    .dc-hero__badge {
        display: inline-block;
        background: linear-gradient(135deg, #e43d51, #c0392b);
        color: #fff;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 6px 18px;
        border-radius: 20px;
        margin-bottom: 16px;
    }
    .dc-hero__title {
        font-size: clamp(24px, 4vw, 36px);
        font-weight: 900;
        color: #1a1a1a;
        margin: 0 0 14px;
        line-height: 1.2;
    }
    .dc-hero__sub {
        font-size: 15px;
        color: #777;
        max-width: 520px;
        margin: 0 auto;
        line-height: 1.6;
    }

    /* ── Group ── */
    .dc-group {
        margin-bottom: 60px;
    }
    .dc-group-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 2px solid #e8e8e8;
    }
    .dc-group-header__left {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .dc-group-icon {
        font-size: 30px;
        line-height: 1;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.15));
    }
    .dc-group-title {
        font-size: 22px;
        font-weight: 900;
        color: #1a1a1a;
        margin: 0;
    }
    .dc-group-count {
        font-size: 12px;
        font-weight: 600;
        color: #aaa;
        background: #f0f0f0;
        padding: 4px 12px;
        border-radius: 20px;
    }

    /* ── Tabs ── */
    .dc-tabs {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 28px;
    }
    .dc-tab {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 9px 16px;
        border: 2px solid #e2e2e2;
        border-radius: 40px;
        background: #fff;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 13.5px;
        font-weight: 700;
        color: #555;
        white-space: nowrap;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    }
    .dc-tab:hover {
        border-color: #e43d51;
        color: #e43d51;
        background: #fff5f6;
        box-shadow: 0 3px 10px rgba(228,61,81,0.15);
    }
    .dc-tab.active {
        border-color: #e43d51;
        background: linear-gradient(135deg, #e43d51, #c0392b);
        color: #fff;
        box-shadow: 0 6px 18px rgba(228,61,81,0.35);
        transform: translateY(-1px);
    }
    .dc-tab__icon {
        font-size: 17px;
        line-height: 1;
        display: flex;
        align-items: center;
    }
    .dc-tab__icon img {
        width: 20px;
        height: 20px;
        object-fit: cover;
        border-radius: 4px;
    }
    .dc-tab__count {
        font-size: 11px;
        font-weight: 700;
        background: rgba(0,0,0,0.1);
        color: inherit;
        padding: 1px 7px;
        border-radius: 10px;
        min-width: 20px;
        text-align: center;
    }
    .dc-tab.active .dc-tab__count {
        background: rgba(255,255,255,0.25);
    }

    /* ── Grid ── */
    .dc-grid {
        display: none;
        grid-template-columns: repeat(4, 1fr);
        gap: 22px;
    }
    .dc-grid.active { display: grid; }

    /* ── Card ── */
    .dc-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #ebebeb;
        display: flex;
        flex-direction: column;
        cursor: pointer;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    .dc-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 40px rgba(0,0,0,0.12);
    }

    /* Card media */
    .dc-card__media {
        position: relative;
        overflow: hidden;
        flex-shrink: 0;
    }
    .dc-card__media img {
        width: 100%;
        height: 175px;
        object-fit: cover;
        display: block;
        transition: transform 0.4s ease;
    }
    .dc-card:hover .dc-card__media img { transform: scale(1.07); }
    .dc-card__placeholder {
        width: 100%;
        height: 175px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 52px;
        background: linear-gradient(135deg, #fff5f6 0%, #f0f4ff 100%);
    }
    .dc-card__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent 45%, rgba(0,0,0,0.45) 100%);
        pointer-events: none;
    }
    .dc-card__price-badge {
        position: absolute;
        bottom: 10px;
        left: 12px;
        background: linear-gradient(135deg, #e43d51, #c0392b);
        color: #fff;
        font-size: 15px;
        font-weight: 900;
        padding: 4px 12px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(228,61,81,0.4);
        letter-spacing: 0.2px;
    }

    /* Card body */
    .dc-card__body {
        padding: 14px 16px 0;
        flex: 1;
    }
    .dc-card__title {
        font-size: 14px;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1.35;
        margin: 0 0 6px;
    }
    .dc-card__desc {
        font-size: 12px;
        color: #999;
        line-height: 1.5;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Card footer */
    .dc-card__footer {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px 16px;
        margin-top: 12px;
        border-top: 1px solid #f3f3f3;
        flex-shrink: 0;
    }

    .dc-card__qty {
        display: flex;
        align-items: center;
        border: 1.5px solid #e8e8e8;
        border-radius: 10px;
        overflow: hidden;
        flex-shrink: 0;
        background: #fafafa;
    }
    .dc-card__qty button {
        width: 30px;
        height: 32px;
        border: none;
        background: transparent;
        font-size: 17px;
        cursor: pointer;
        color: #666;
        transition: background 0.15s, color 0.15s;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 400;
    }
    .dc-card__qty button:hover { background: #e43d51; color: #fff; }
    .dc-card__qty-val {
        min-width: 30px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: #222;
        border-left: 1.5px solid #e8e8e8;
        border-right: 1.5px solid #e8e8e8;
        padding: 0 4px;
        user-select: none;
        background: #fff;
    }

    .dc-card__btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 9px 10px;
        background: linear-gradient(135deg, #e43d51, #c0392b);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 12.5px;
        font-weight: 800;
        cursor: pointer;
        letter-spacing: 0.3px;
        transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
        white-space: nowrap;
        min-width: 0;
        box-shadow: 0 4px 12px rgba(228,61,81,0.3);
    }
    .dc-card__btn-icon { font-size: 14px; }
    .dc-card__btn:hover {
        opacity: 0.9;
        transform: scale(1.03);
        box-shadow: 0 6px 18px rgba(228,61,81,0.4);
    }
    .dc-card__btn:active { transform: scale(0.97); }
    .dc-card__btn:disabled {
        background: #ddd;
        box-shadow: none;
        cursor: not-allowed;
        transform: none;
    }

    /* ── Toast ── */
    .dc-toast {
        position: fixed;
        bottom: 28px;
        right: 28px;
        z-index: 9999;
        padding: 14px 22px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        display: none;
        box-shadow: 0 10px 28px rgba(0,0,0,0.18);
        max-width: 320px;
        animation: dcSlideIn 0.3s ease;
    }
    @@keyframes dcSlideIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .dc-toast.success { background: #1b5e20; color: #fff; }
    .dc-toast.error   { background: #b71c1c; color: #fff; }

    /* ── Responsive ── */
    @@media (max-width: 1199px) {
        .dc-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 767px) {
        .dc-section { padding: 36px 0 48px; }
        .dc-hero { margin-bottom: 36px; }
        .dc-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
        .dc-tab { padding: 8px 13px; font-size: 13px; }
        .dc-group-title { font-size: 19px; }
    }
    @@media (max-width: 479px) {
        .dc-grid { grid-template-columns: 1fr 1fr; gap: 10px; }
        .dc-card__media img,
        .dc-card__placeholder { height: 130px; }
        .dc-card__price-badge { font-size: 13px; }
        .dc-card__btn { font-size: 11.5px; padding: 8px 6px; }
        .dc-hero__badge { font-size: 11px; }
    }
</style>

<script>
(function () {
    document.querySelectorAll('.dc-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.dc-tab').forEach(function (b) {
                b.classList.remove('active');
                b.setAttribute('aria-selected', 'false');
            });
            btn.classList.add('active');
            btn.setAttribute('aria-selected', 'true');

            document.querySelectorAll('.dc-grid').forEach(function (g) { g.classList.remove('active'); });
            var grid = document.getElementById('cat-' + btn.dataset.cat);
            if (grid) grid.classList.add('active');
        });
    });

    document.querySelectorAll('.dc-card').forEach(function (card) {
        var input   = card.querySelector('.qty-input');
        var display = card.querySelector('.dc-card__qty-val');
        card.querySelector('.qty-minus').addEventListener('click', function (e) {
            e.stopPropagation();
            var v = Math.max(1, (parseInt(input.value) || 1) - 1);
            input.value = v; display.textContent = v;
        });
        card.querySelector('.qty-plus').addEventListener('click', function (e) {
            e.stopPropagation();
            var v = (parseInt(input.value) || 1) + 1;
            input.value = v; display.textContent = v;
        });
        card.addEventListener('click', function (e) {
            if (!e.target.closest('.dc-card__footer')) {
                window.location.href = card.dataset.href;
            }
        });
    });

    document.querySelectorAll('.dc-card__btn').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var card = btn.closest('.dc-card');
            var qty = parseInt(card.querySelector('.qty-input').value) || 1;
            btn.disabled = true;
            AjaxCart.addproducttocart_catalog('/addproducttocart/catalog/' + btn.dataset.productId + '/1/' + qty);
            setTimeout(function () { btn.disabled = false; }, 1500);
        });
    });
})();
</script>
