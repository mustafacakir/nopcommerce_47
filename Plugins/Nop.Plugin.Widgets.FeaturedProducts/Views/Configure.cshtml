@model Nop.Plugin.Widgets.FeaturedProducts.Models.ConfigurationModel
@{
    Layout = "_ConfigurePlugin";
}

@await Component.InvokeAsync("StoreScopeConfiguration")
<form asp-controller="WidgetsFeaturedProducts" asp-action="Configure" method="post">
    <div class="panel-group">
        <div class="panel panel-default">
            <div class="panel-heading">Featured Products Ayarları</div>
            <div class="panel-body">

                @foreach (var field in new[] {
                    ("SectionBadge",   "Rozet Metni"),
                    ("SectionTitle",   "Başlık"),
                    ("SectionSubtitle","Alt Başlık"),
                    ("ViewAllText",    "Tüm Ürünler Butonu Metni"),
                    ("ViewAllUrl",     "Tüm Ürünler Butonu Linki"),
                    ("ProductCount",   "Gösterilecek Ürün Sayısı (maks 8 önerilir)"),
                })
                {
                    <div class="form-group row">
                        <div class="col-md-3"><label>@field.Item2</label></div>
                        <div class="col-md-9">
                            <input type="text" name="@field.Item1"
                                   value="@(Model.GetType().GetProperty(field.Item1)?.GetValue(Model))"
                                   class="form-control" />
                        </div>
                    </div>
                }

                <div class="form-group row">
                    <div class="col-md-9 col-md-offset-3">
                        <small class="text-muted">
                            Ürünlerin anasayfada görünmesi için ürün yönetiminde
                            <strong>"Anasayfada Göster"</strong> seçeneğini işaretleyin.
                        </small>
                    </div>
                </div>

            </div>
        </div>
        <div class="panel panel-default">
            <div class="panel-body">
                <div class="form-group row">
                    <div class="col-md-9 col-md-offset-3">
                        <input type="submit" name="save" class="btn bg-blue" value="@T("Admin.Common.Save")" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
