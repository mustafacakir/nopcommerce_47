@model Nop.Plugin.Widgets.FeaturedProducts.Models.PublicInfoModel
@{ Layout = ""; }

@* Geçici olarak devre dışı *@
@{ return; }

@if (!Model.Products.Any())
{
    return;
}

<section class="fp-section">
    <div class="fp-container">

        <!-- Başlık -->
        <div class="fp-header">
            @if (!string.IsNullOrEmpty(Model.SectionBadge))
            {
                <span class="fp-badge">@Model.SectionBadge</span>
            }
            @if (!string.IsNullOrEmpty(Model.SectionTitle))
            {
                <h2 class="fp-title">@Model.SectionTitle</h2>
            }
            @if (!string.IsNullOrEmpty(Model.SectionSubtitle))
            {
                <p class="fp-subtitle">@Model.SectionSubtitle</p>
            }
        </div>

        <!-- Ürün grid -->
        <div class="fp-grid">
            @foreach (var p in Model.Products)
            {
                <article class="fp-card" data-href="/@p.SeName">

                    <div class="fp-card__img-wrap">
                        <img src="@p.ImageUrl" alt="@p.Name" loading="lazy" class="fp-card__img" />
                        @if (p.HasDiscount)
                        {
                            <span class="fp-card__discount-tag">İndirim</span>
                        }
                    </div>

                    <div class="fp-card__body">
                        @if (!string.IsNullOrEmpty(p.CategoryName))
                        {
                            <span class="fp-card__cat">@p.CategoryName</span>
                        }
                        <h3 class="fp-card__name">@p.Name</h3>

                        @if (p.ReviewCount > 0)
                        {
                            <div class="fp-card__rating">
                                <div class="fp-stars">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <svg class="fp-star @(s <= Math.Round(p.Rating) ? "fp-star--filled" : "")"
                                             viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                        </svg>
                                    }
                                </div>
                                <span class="fp-card__review-count">(@p.ReviewCount)</span>
                            </div>
                        }

                        <div class="fp-card__price">
                            <span class="fp-card__price-current">@p.Price</span>
                            @if (p.HasDiscount && !string.IsNullOrEmpty(p.OldPrice))
                            {
                                <span class="fp-card__price-old">@p.OldPrice</span>
                            }
                        </div>
                    </div>

                    <div class="fp-card__footer">
                        <button class="fp-card__btn" data-product-id="@p.Id" type="button">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                            </svg>
                            Sepete Ekle
                        </button>
                    </div>

                </article>
            }
        </div>

        <!-- Tüm ürünler butonu -->
        @if (!string.IsNullOrEmpty(Model.ViewAllUrl))
        {
            <div class="fp-footer">
                <a href="@Model.ViewAllUrl" class="fp-btn-all">
                    @(string.IsNullOrEmpty(Model.ViewAllText) ? "Tüm Ürünleri Gör" : Model.ViewAllText)
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>
        }

    </div>
</section>

<style>
    .fp-section {
        background: #FAF7F2;
        padding: 64px 24px;
        font-family: 'Poppins', sans-serif;
    }

    .fp-container {
        max-width: 1180px;
        margin: 0 auto;
    }

    /* ── Başlık ── */
    .fp-header {
        text-align: center;
        margin-bottom: 48px;
    }
    .fp-badge {
        display: inline-block;
        background: #FDF0E6;
        color: #C96A2A;
        font-size: 12px;
        font-weight: 600;
        padding: 6px 14px;
        border-radius: 20px;
        margin-bottom: 14px;
        letter-spacing: 0.3px;
        font-family: 'Poppins', sans-serif;
    }
    .fp-title {
        font-size: clamp(24px, 3vw, 36px);
        font-weight: 700;
        color: #1A1A1A;
        margin: 0 0 10px;
        letter-spacing: -0.3px;
        font-family: 'Poppins', sans-serif;
    }
    .fp-subtitle {
        font-size: 15px;
        color: #888;
        margin: 0;
        font-family: 'Poppins', sans-serif;
    }

    /* ── Grid ── */
    .fp-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    /* ── Kart ── */
    .fp-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        cursor: pointer;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .fp-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.1);
    }

    /* Görsel */
    .fp-card__img-wrap {
        position: relative;
        aspect-ratio: 1;
        overflow: hidden;
        background: #EDE8E0;
    }
    .fp-card__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.4s ease;
    }
    .fp-card:hover .fp-card__img { transform: scale(1.06); }

    .fp-card__discount-tag {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #C96A2A;
        color: #fff;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 20px;
        letter-spacing: 0.3px;
        font-family: 'Poppins', sans-serif;
    }

    /* İçerik */
    .fp-card__body {
        padding: 14px 16px 12px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
    }
    .fp-card__cat {
        font-size: 11px;
        font-weight: 600;
        color: #C96A2A;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-family: 'Poppins', sans-serif;
    }
    .fp-card__name {
        font-size: 14px;
        font-weight: 600;
        color: #1A1A1A;
        margin: 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-family: 'Poppins', sans-serif;
    }

    /* Yıldızlar */
    .fp-card__rating {
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .fp-stars {
        display: flex;
        gap: 2px;
    }
    .fp-star {
        width: 13px;
        height: 13px;
        color: #DDD;
    }
    .fp-star--filled { color: #F59E0B; }
    .fp-card__review-count {
        font-size: 11.5px;
        color: #AAA;
        font-family: 'Poppins', sans-serif;
    }

    /* Fiyat */
    .fp-card__price {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: auto;
        padding-bottom: 4px;
    }
    .fp-card__price-current {
        font-size: 16px;
        font-weight: 700;
        color: #C96A2A;
        font-family: 'Poppins', sans-serif;
    }
    .fp-card__price-old {
        font-size: 13px;
        color: #AAA;
        text-decoration: line-through;
        font-family: 'Poppins', sans-serif;
    }

    /* ── Sepete ekle ── */
    .fp-card__footer {
        padding: 0 16px 16px;
    }
    .fp-card__btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 8px;
        border: 1.5px solid #1A1A1A;
        background: transparent;
        color: #1A1A1A;
        font-size: 13px;
        font-weight: 600;
        font-family: 'Poppins', sans-serif;
        cursor: pointer;
        transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .fp-card__btn:hover {
        background: #C96A2A;
        border-color: #C96A2A;
        color: #fff;
    }
    .fp-card__btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    /* ── Footer butonu ── */
    .fp-footer {
        margin-top: 48px;
        text-align: center;
    }
    .fp-btn-all {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 32px;
        border-radius: 8px;
        border: 1.5px solid #1A1A1A;
        background: transparent;
        color: #1A1A1A;
        font-size: 14px;
        font-weight: 600;
        font-family: 'Poppins', sans-serif;
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
    }
    .fp-btn-all:hover {
        background: #1A1A1A;
        color: #FAF7F2;
    }

    /* ── Responsive ── */
    @@media (max-width: 1024px) {
        .fp-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 767px) {
        .fp-section { padding: 48px 20px; }
        .fp-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    }
    @@media (max-width: 480px) {
        .fp-grid { grid-template-columns: 1fr; }
    }
</style>

<script>
(function () {
    document.querySelectorAll('.fp-card').forEach(function (card) {
        card.addEventListener('click', function (e) {
            if (!e.target.closest('.fp-card__footer')) {
                window.location.href = card.dataset.href;
            }
        });
    });

    document.querySelectorAll('.fp-card__btn').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            btn.disabled = true;
            AjaxCart.addproducttocart_catalog('/addproducttocart/catalog/' + btn.dataset.productId + '/1/1');
            setTimeout(function () { btn.disabled = false; }, 1500);
        });
    });
})();
</script>
