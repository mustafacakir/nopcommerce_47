@model Nop.Plugin.Widgets.FeaturedProducts.Models.PublicInfoModel
@{ Layout = ""; }

@if (!Model.Products.Any())
{
    return;
}

<section class="fp-section">
    <div class="fp-container">

        <!-- Başlık -->
        <div class="fp-header">
            @if (!string.IsNullOrEmpty(Model.SectionBadge))
            {
                <span class="fp-badge">@Model.SectionBadge</span>
            }
            @if (!string.IsNullOrEmpty(Model.SectionTitle))
            {
                <h2 class="fp-title">@Model.SectionTitle</h2>
            }
            @if (!string.IsNullOrEmpty(Model.SectionSubtitle))
            {
                <p class="fp-subtitle">@Model.SectionSubtitle</p>
            }
        </div>

        <!-- Ürün grid -->
        <div class="fp-grid">
            @foreach (var p in Model.Products)
            {
                <article class="fp-card" data-href="/@p.SeName">

                    <a href="/@p.SeName" class="fp-card__img-wrap">
                        <img src="@p.ImageUrl" alt="@p.Name" loading="lazy" class="fp-card__img" />
                        @if (p.HasDiscount)
                        {
                            <span class="fp-card__discount-tag">İndirim</span>
                        }
                    </a>

                    <div class="fp-card__body">
                        @if (!string.IsNullOrEmpty(p.CategoryName))
                        {
                            <span class="fp-card__cat">@p.CategoryName</span>
                        }
                        <h3 class="fp-card__name">@p.Name</h3>

                        @if (p.ReviewCount > 0)
                        {
                            <div class="fp-card__rating">
                                <div class="fp-stars">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <svg class="fp-star @(s <= Math.Round(p.Rating) ? "fp-star--filled" : "")"
                                             viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                        </svg>
                                    }
                                </div>
                                <span class="fp-card__review-count">(@p.ReviewCount)</span>
                            </div>
                        }

                        <div class="fp-card__price">
                            <span class="fp-card__price-current">@p.Price</span>
                            @if (p.HasDiscount && !string.IsNullOrEmpty(p.OldPrice))
                            {
                                <span class="fp-card__price-old">@p.OldPrice</span>
                            }
                        </div>
                    </div>

                    <div class="fp-card__footer">
                        <button class="fp-card__btn" data-product-id="@p.Id" type="button">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                            </svg>
                            Sepete Ekle
                        </button>
                    </div>

                </article>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.ViewAllUrl))
        {
            <div class="fp-footer">
                <a href="@Model.ViewAllUrl" class="fp-btn-all">
                    @(string.IsNullOrEmpty(Model.ViewAllText) ? "Tüm Ürünleri Gör" : Model.ViewAllText)
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>
        }

    </div>
</section>

<style>
    .fp-section {
        background: #FAF0E6;
        padding: 72px 32px 96px;
        font-family: 'Poppins', 'Segoe UI', sans-serif;
    }

    .fp-container {
        max-width: 1280px;
        margin: 0 auto;
    }

    /* ── Başlık ── */
    .fp-header {
        text-align: center;
        margin-bottom: 56px;
    }
    .fp-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(196,168,130,0.15);
        border: 1px solid rgba(196,168,130,0.35);
        color: #8B6343;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 6px 18px;
        border-radius: 20px;
        margin-bottom: 16px;
    }
    .fp-title {
        font-size: clamp(24px, 3vw, 32px);
        font-weight: 800;
        color: #2C1508;
        margin: 0 0 10px;
        letter-spacing: -0.5px;
    }
    .fp-title::after {
        content: '';
        display: block;
        width: 44px;
        height: 3px;
        background: linear-gradient(90deg, #C4A882, #8B6343);
        border-radius: 2px;
        margin: 14px auto 0;
    }
    .fp-subtitle {
        font-size: 15px;
        color: #8B6343;
        margin: 10px 0 0;
    }

    /* ── Grid ── */
    .fp-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    /* ── Kart ── */
    .fp-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 1px 4px rgba(61,35,20,0.06), 0 4px 16px rgba(61,35,20,0.06);
        border: 1px solid rgba(196,168,130,0.18);
        transition: transform .28s cubic-bezier(.4,0,.2,1), box-shadow .28s;
    }
    .fp-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 2px 8px rgba(61,35,20,0.08), 0 16px 40px rgba(61,35,20,0.14);
    }

    /* Görsel */
    .fp-card__img-wrap {
        display: block;
        position: relative;
        aspect-ratio: 1;
        overflow: hidden;
        background: #F5EDE3;
        text-decoration: none;
    }
    .fp-card__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform .4s cubic-bezier(.4,0,.2,1);
    }
    .fp-card:hover .fp-card__img { transform: scale(1.07); }

    .fp-card__discount-tag {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #7A4528;
        color: #FAF0E6;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 20px;
        letter-spacing: 0.3px;
    }

    /* İçerik */
    .fp-card__body {
        padding: 14px 16px 10px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
    }
    .fp-card__cat {
        font-size: 11px;
        font-weight: 600;
        color: #8B6343;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .fp-card__name {
        font-size: 13.5px;
        font-weight: 600;
        color: #2C1508;
        margin: 0;
        line-height: 1.45;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    /* Yıldızlar */
    .fp-card__rating {
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .fp-stars { display: flex; gap: 2px; }
    .fp-star { width: 13px; height: 13px; color: rgba(196,168,130,0.3); }
    .fp-star--filled { color: #C4A882; }
    .fp-card__review-count { font-size: 11.5px; color: #8B6343; }

    /* Fiyat */
    .fp-card__price {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: auto;
    }
    .fp-card__price-current {
        font-size: 17px;
        font-weight: 800;
        color: #7A4528;
        letter-spacing: -0.3px;
    }
    .fp-card__price-old {
        font-size: 13px;
        color: #C4A882;
        text-decoration: line-through;
    }

    /* ── Sepete ekle ── */
    .fp-card__footer { padding: 0 16px 16px; }
    .fp-card__btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 11px 0;
        border-radius: 10px;
        border: none;
        background: #2C1508;
        color: #FAF0E6;
        font-size: 13px;
        font-weight: 600;
        font-family: 'Poppins', 'Segoe UI', sans-serif;
        letter-spacing: 0.2px;
        cursor: pointer;
        transition: background .2s, transform .15s;
    }
    .fp-card__btn:hover {
        background: #7A4528;
        transform: translateY(-1px);
    }
    .fp-card__btn:disabled { opacity: 0.6; cursor: not-allowed; }

    /* ── Footer butonu ── */
    .fp-footer {
        margin-top: 56px;
        text-align: center;
    }
    .fp-btn-all {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 15px 44px;
        border-radius: 50px;
        background: #2C1508;
        color: #FAF0E6;
        font-size: 15px;
        font-weight: 700;
        font-family: 'Poppins', 'Segoe UI', sans-serif;
        text-decoration: none;
        transition: background .2s, transform .2s, box-shadow .2s;
        box-shadow: 0 4px 16px rgba(44,21,8,0.2);
    }
    .fp-btn-all:hover {
        background: #7A4528;
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(44,21,8,0.28);
        color: #FAF0E6;
        text-decoration: none;
    }

    /* ── Responsive ── */
    @@media (max-width: 1024px) {
        .fp-grid { grid-template-columns: repeat(3, 1fr); }
        .fp-section { padding: 56px 24px 72px; }
    }
    @@media (max-width: 767px) {
        .fp-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
        .fp-section { padding: 48px 20px 64px; }
    }
    @@media (max-width: 480px) {
        .fp-grid { grid-template-columns: 1fr; }
    }
</style>

<script>
(function () {
    document.querySelectorAll('.fp-card__btn').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            btn.disabled = true;
            AjaxCart.addproducttocart_catalog('/addproducttocart/catalog/' + btn.dataset.productId + '/1/1');
            setTimeout(function () { btn.disabled = false; }, 1500);
        });
    });
})();
</script>
