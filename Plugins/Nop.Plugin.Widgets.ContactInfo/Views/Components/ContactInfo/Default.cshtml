@using Nop.Plugin.Widgets.ContactInfo
@model ContactInfoSettings
@{ Layout = ""; }

@{
    var hasPhone    = !string.IsNullOrEmpty(Model.Phone);
    var hasWhatsApp = !string.IsNullOrEmpty(Model.WhatsApp);
    var hasEmail    = !string.IsNullOrEmpty(Model.Email);
    var hasAddress  = !string.IsNullOrEmpty(Model.Address);
    var hasMap      = !string.IsNullOrEmpty(Model.MapEmbedUrl);
    var hasFb       = !string.IsNullOrEmpty(Model.FacebookUrl);
    var hasIg       = !string.IsNullOrEmpty(Model.InstagramUrl);
    var hasTw       = !string.IsNullOrEmpty(Model.TwitterUrl);
    var hasYt       = !string.IsNullOrEmpty(Model.YoutubeUrl);
    var hasSocial   = hasFb || hasIg || hasTw || hasYt;
    var hasAnyCard  = hasPhone || hasWhatsApp || hasEmail || hasAddress;
}

@if (!hasAnyCard && !hasMap && !hasSocial) { return; }

<div class="ci-wrap">

    @if (hasAnyCard)
    {
        <div class="ci-cards">
            @if (hasPhone)
            {
                <a class="ci-card" href="tel:@Model.Phone">
                    <span class="ci-card-ico ci-ico-phone">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.86a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    </span>
                    <div class="ci-card-body">
                        <span class="ci-card-label">Telefon</span>
                        <span class="ci-card-val">@Model.Phone</span>
                    </div>
                </a>
            }
            @if (hasWhatsApp)
            {
                var waNumber = System.Text.RegularExpressions.Regex.Replace(Model.WhatsApp, @"[^\d+]", "");
                <a class="ci-card" href="https://wa.me/@waNumber.TrimStart('+')" target="_blank" rel="noopener">
                    <span class="ci-card-ico ci-ico-whatsapp">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                    </span>
                    <div class="ci-card-body">
                        <span class="ci-card-label">WhatsApp</span>
                        <span class="ci-card-val">@Model.WhatsApp</span>
                    </div>
                </a>
            }
            @if (hasEmail)
            {
                <a class="ci-card" href="mailto:@Model.Email">
                    <span class="ci-card-ico ci-ico-email">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </span>
                    <div class="ci-card-body">
                        <span class="ci-card-label">E-posta</span>
                        <span class="ci-card-val">@Model.Email</span>
                    </div>
                </a>
            }
            @if (hasAddress)
            {
                <div class="ci-card ci-card--address">
                    <span class="ci-card-ico ci-ico-address">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </span>
                    <div class="ci-card-body">
                        <span class="ci-card-label">Adres</span>
                        <span class="ci-card-val">@Model.Address</span>
                    </div>
                </div>
            }
        </div>
    }

    @if (hasMap)
    {
        <div class="ci-map">
            @if (Model.MapEmbedUrl.TrimStart().StartsWith("<iframe", StringComparison.OrdinalIgnoreCase))
            {
                @Html.Raw(Model.MapEmbedUrl)
            }
            else
            {
                <iframe src="@Model.MapEmbedUrl" width="100%" height="320" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            }
        </div>
    }

    @if (hasSocial)
    {
        <div class="ci-social">
            <span class="ci-social-label">Bizi takip edin</span>
            <div class="ci-social-links">
                @if (hasFb)
                {
                    <a href="@Model.FacebookUrl" class="ci-social-link ci-sl-fb" target="_blank" rel="noopener" title="Facebook">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                }
                @if (hasIg)
                {
                    <a href="@Model.InstagramUrl" class="ci-social-link ci-sl-ig" target="_blank" rel="noopener" title="Instagram">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
                    </a>
                }
                @if (hasTw)
                {
                    <a href="@Model.TwitterUrl" class="ci-social-link ci-sl-tw" target="_blank" rel="noopener" title="Twitter/X">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                }
                @if (hasYt)
                {
                    <a href="@Model.YoutubeUrl" class="ci-social-link ci-sl-yt" target="_blank" rel="noopener" title="YouTube">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                }
            </div>
        </div>
    }

</div>

<style>
.ci-wrap { margin-bottom: 40px; display: flex; flex-direction: column; gap: 20px; }

/* Kartlar */
.ci-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
}
.ci-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 18px 16px;
    text-decoration: none;
    transition: border-color .15s, box-shadow .15s;
}
.ci-card:hover { border-color: #93c5fd; box-shadow: 0 2px 12px rgba(59,130,246,.08); }
.ci-card--address { cursor: default; }
.ci-card--address:hover { border-color: #e5e7eb; box-shadow: none; }

.ci-card-ico {
    width: 42px; height: 42px; flex-shrink: 0;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
}
.ci-ico-phone    { background: #eff6ff; color: #3b82f6; }
.ci-ico-whatsapp { background: #f0fdf4; color: #16a34a; }
.ci-ico-email    { background: #fef3c7; color: #d97706; }
.ci-ico-address  { background: #fdf2f8; color: #db2777; }

.ci-card-body { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
.ci-card-label { font-size: .72rem; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: .5px; }
.ci-card-val   { font-size: .88rem; font-weight: 600; color: #111827; line-height: 1.4; word-break: break-word; }

/* Harita */
.ci-map { border-radius: 14px; overflow: hidden; border: 1px solid #e5e7eb; }
.ci-map iframe { width: 100% !important; display: block; }

/* Sosyal medya */
.ci-social {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
}
.ci-social-label { font-size: .8rem; font-weight: 700; color: #6b7280; white-space: nowrap; }
.ci-social-links { display: flex; gap: 8px; flex-wrap: wrap; }
.ci-social-link {
    width: 38px; height: 38px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    transition: opacity .15s, transform .15s;
    color: #fff;
}
.ci-social-link:hover { opacity: .85; transform: translateY(-2px); }
.ci-sl-fb { background: #1877f2; }
.ci-sl-ig { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
.ci-sl-tw { background: #000; }
.ci-sl-yt { background: #ff0000; }

@@media (max-width: 600px) {
    .ci-cards { grid-template-columns: 1fr 1fr; }
}
@@media (max-width: 400px) {
    .ci-cards { grid-template-columns: 1fr; }
}
</style>
