@model Nop.Plugin.Widgets.ImpactCounter.Models.PublicInfoModel
@{ Layout = ""; }

<section class="impact-section">
    <div class="impact-grid">
        @foreach (var stat in Model.Stats)
        {
            <div class="impact-card">
                <div class="impact-icon">@stat.Icon</div>
                <div class="impact-value" data-target="@stat.Value">@stat.Value</div>
                <div class="impact-label">@stat.Label</div>
            </div>
        }
    </div>
</section>

<style>
    .impact-section {
        padding: 40px 24px;
        background: #fff;
        border-bottom: 1px solid #f0f0f0;
    }
    .impact-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        max-width: 900px;
        margin: 0 auto;
    }
    .impact-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 20px 16px;
        border-right: 1px solid #f0f0f0;
        text-align: center;
    }
    .impact-card:last-child { border-right: none; }
    .impact-icon { font-size: 32px; line-height: 1; }
    .impact-value {
        font-size: 32px;
        font-weight: 900;
        color: #e43d51;
        line-height: 1;
        letter-spacing: -0.5px;
    }
    .impact-label {
        font-size: 13px;
        font-weight: 600;
        color: #777;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    @@media (max-width: 767px) {
        .impact-grid { grid-template-columns: repeat(2, 1fr); }
        .impact-card:nth-child(2) { border-right: none; }
        .impact-card:nth-child(3) { border-right: 1px solid #f0f0f0; }
        .impact-card:nth-child(3),
        .impact-card:nth-child(4) { border-top: 1px solid #f0f0f0; }
        .impact-value { font-size: 26px; }
    }
</style>
