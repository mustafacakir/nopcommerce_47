@using Nop.Plugin.Widgets.CampaignProgress.Models.Public
@model List<CampaignWidgetItemModel>

<section class="cp-section">
    <div class="cp-container">
        <div class="cp-header">
            <h2 class="cp-heading">Aktif Projelerimiz</h2>
            <p class="cp-subheading">Her bağış, bir umudun filizlenmesidir</p>
        </div>
        <div class="cp-grid">
            @foreach (var item in Model)
            {
                <a href="/proje/@item.Slug" class="cp-card">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <div class="cp-card-img" style="background-image:url('@item.ImageUrl')"></div>
                    }
                    else
                    {
                        <div class="cp-card-img cp-card-img--placeholder"></div>
                    }
                    <div class="cp-card-body">
                        <h3 class="cp-card-title">@item.Title</h3>
                        <div class="cp-progress-wrap">
                            <div class="cp-progress-bar">
                                <div class="cp-progress-fill" style="width:@item.ProgressPercent%"></div>
                            </div>
                            <span class="cp-progress-pct">%@item.ProgressPercent</span>
                        </div>
                        <div class="cp-amounts">
                            <span class="cp-raised">@item.CurrentAmount.ToString("N0") ₺ toplandı</span>
                            <span class="cp-goal">Hedef: @item.GoalAmount.ToString("N0") ₺</span>
                        </div>
                        <span class="cp-btn">Destek Ol</span>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

<style>
.cp-section {padding: 60px 0; }
.cp-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
.cp-header { text-align: center; margin-bottom: 40px; }
.cp-heading { font-size: 2rem; font-weight: 700; color: #1a3d1f; margin: 0 0 10px; }
.cp-subheading { color: #5a7a5f; font-size: 1.05rem; margin: 0; }
.cp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }
.cp-card { display: flex; flex-direction: column; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,.08); text-decoration: none; color: inherit; transition: transform .2s, box-shadow .2s; }
.cp-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,.13); }
.cp-card-img { height: 180px; background: center/cover no-repeat; }
.cp-card-img--placeholder { background: linear-gradient(135deg, #2d7a3a, #4caf65); }
.cp-card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 12px; }
.cp-card-title { font-size: 1rem; font-weight: 600; color: #1a3d1f; margin: 0; line-height: 1.4; }
.cp-progress-wrap { display: flex; align-items: center; gap: 10px; }
.cp-progress-bar { flex: 1; height: 8px; background: #e5ede6; border-radius: 4px; overflow: hidden; }
.cp-progress-fill { height: 100%; background: linear-gradient(90deg, #2d7a3a, #4caf65); border-radius: 4px; transition: width .6s ease; }
.cp-progress-pct { font-size: .8rem; font-weight: 700; color: #2d7a3a; min-width: 36px; text-align: right; }
.cp-amounts { display: flex; justify-content: space-between; font-size: .82rem; }
.cp-raised { color: #2d7a3a; font-weight: 600; }
.cp-goal { color: #888; }
.cp-btn { display: inline-block; margin-top: auto; background: #2d7a3a; color: #fff; text-align: center; padding: 10px 0; border-radius: 8px; font-size: .9rem; font-weight: 600; letter-spacing: .3px; }
.cp-card:hover .cp-btn { background: #245f2e; }
@@media (max-width: 600px) { .cp-grid { grid-template-columns: 1fr; } .cp-heading { font-size: 1.5rem; } }
</style>
