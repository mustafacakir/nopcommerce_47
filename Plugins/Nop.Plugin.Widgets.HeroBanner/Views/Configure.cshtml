@model Nop.Plugin.Widgets.HeroBanner.Models.ConfigurationModel
@{
    Layout = "_ConfigurePlugin";
}

@await Component.InvokeAsync("StoreScopeConfiguration")
<form asp-controller="WidgetsHeroBanner" asp-action="Configure" method="post">
    <div class="panel-group">
        <div class="panel panel-default">
            <div class="panel-heading">Hero Banner Ayarları</div>
            <div class="panel-body">

                @foreach (var field in new[] {
                    ("Title", "Başlık"),
                    ("Subtitle", "Alt Başlık"),
                    ("ButtonText", "Buton Yazısı"),
                    ("ButtonUrl", "Buton Linki"),
                    ("BackgroundColor", "Arka Plan Rengi"),
                    ("AccentColor", "Vurgu Rengi"),
                    ("BackgroundImageUrl", "Arka Plan Görseli URL"),
                    ("Stat1Icon", "İstatistik 1 — İkon (emoji)"),
                    ("Stat1Value", "İstatistik 1 — Değer (örn: 10.000+)"),
                    ("Stat1Label", "İstatistik 1 — Etiket (örn: Mutlu Aile)"),
                    ("Stat2Icon", "İstatistik 2 — İkon (emoji)"),
                    ("Stat2Value", "İstatistik 2 — Değer (örn: 40+)"),
                    ("Stat2Label", "İstatistik 2 — Etiket (örn: Ülkede Yardım)")
                })
                {
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label>@field.Item2</label>
                        </div>
                        <div class="col-md-9">
                            <input type="text" name="@field.Item1" value="@(Model.GetType().GetProperty(field.Item1)?.GetValue(Model))" class="form-control" />
                        </div>
                    </div>
                }

            </div>
        </div>
        <div class="panel panel-default">
            <div class="panel-body">
                <div class="form-group row">
                    <div class="col-md-9 col-md-offset-3">
                        <input type="submit" name="save" class="btn bg-blue" value="@T("Admin.Common.Save")" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
