@model Nop.Plugin.Widgets.DonationGrid.Models.ConfigureModel
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Donation Grid Ayarları";
}

<div class="content-header clearfix">
    <h1 class="pull-left">Donation Grid</h1>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div asp-validation-summary="All" class="alert alert-danger"></div>
            <form asp-controller="DonationGrid" asp-action="Configure" method="post">
                <input asp-for="ActiveStoreScopeConfiguration" type="hidden" />

                @if (Model.ActiveStoreScopeConfiguration > 0)
                {
                    <nop-override-store-checkbox asp-for="RootCategoryId_OverrideForStore"
                                                asp-input="RootCategoryId"
                                                asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                }

                <div class="form-group row">
                    <div class="col-md-3">
                        <nop-label asp-for="RootCategoryId" />
                    </div>
                    <div class="col-md-9">
                        <input asp-for="RootCategoryId" class="form-control" type="number" min="0" />
                        <span asp-validation-for="RootCategoryId"></span>
                        <div class="form-text text-muted">
                            Widget'ın görüneceği kategori ID'si. 0 girilirse tüm kategori sayfalarında gösterir.
                        </div>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-md-9 offset-md-3">
                        <button type="submit" name="save" class="btn btn-primary">Kaydet</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>
