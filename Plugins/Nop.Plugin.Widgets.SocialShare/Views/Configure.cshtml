@model Nop.Plugin.Widgets.SocialShare.Models.ConfigurationModel
@{ Layout = "_ConfigurePlugin"; }

@await Component.InvokeAsync("StoreScopeConfiguration")
<form asp-controller="WidgetsSocialShare" asp-action="Configure" method="post">
    <div class="panel-group">
        <div class="panel panel-default">
            <div class="panel-heading">Sosyal Paylaşım Ayarları</div>
            <div class="panel-body">
                <div class="form-group row">
                    <div class="col-md-3"><label>Başlık</label></div>
                    <div class="col-md-9"><input type="text" name="Title" value="@Model.Title" class="form-control" /></div>
                </div>
                <div class="form-group row">
                    <div class="col-md-3"><label>WhatsApp Göster</label></div>
                    <div class="col-md-9"><input type="checkbox" name="ShowWhatsApp" value="true" @(Model.ShowWhatsApp ? "checked" : "") /></div>
                </div>
                <div class="form-group row">
                    <div class="col-md-3"><label>Facebook Göster</label></div>
                    <div class="col-md-9"><input type="checkbox" name="ShowFacebook" value="true" @(Model.ShowFacebook ? "checked" : "") /></div>
                </div>
                <div class="form-group row">
                    <div class="col-md-3"><label>X (Twitter) Göster</label></div>
                    <div class="col-md-9"><input type="checkbox" name="ShowX" value="true" @(Model.ShowX ? "checked" : "") /></div>
                </div>
                <div class="form-group row">
                    <div class="col-md-3"><label>Link Kopyala Göster</label></div>
                    <div class="col-md-9"><input type="checkbox" name="ShowCopyLink" value="true" @(Model.ShowCopyLink ? "checked" : "") /></div>
                </div>
            </div>
        </div>
        <div class="panel panel-default">
            <div class="panel-body">
                <div class="form-group row">
                    <div class="col-md-9 col-md-offset-3">
                        <input type="submit" name="save" class="btn bg-blue" value="@T("Admin.Common.Save")" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
