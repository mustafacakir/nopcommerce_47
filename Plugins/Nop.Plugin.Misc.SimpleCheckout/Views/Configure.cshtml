@model Nop.Plugin.Misc.SimpleCheckout.SimpleCheckoutSettings
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Simple Checkout Ayarları";
}
<div class="content-header clearfix">
    <h1 class="pull-left">Simple Checkout</h1>
</div>
<section class="content">
    <div class="container-fluid">
        @if (ViewBag.Saved == true)
        {
            <div class="alert alert-success">Kaydedildi.</div>
        }
        <form asp-controller="SimpleCheckoutAdmin" asp-action="Configure" method="post">
            <div class="card card-default">
                <div class="card-body">
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label>Dernek Mağaza ID'leri</label>
                        </div>
                        <div class="col-md-9">
                            <input asp-for="DonationStoreIds" class="form-control" placeholder="1,3,5" />
                            <span class="form-text text-muted">Virgülle ayrılmış Store ID'leri. Bu mağazalarda OPC → /checkout/bagis'e yönlendirilir.</span>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label>EFT / Havale Açıklaması</label>
                        </div>
                        <div class="col-md-9">
                            <textarea asp-for="EftDescription" class="form-control" rows="6" placeholder="EFT/havale ile ödeme yapılacak mağazalarda checkout sayfasında gösterilecek metin (HTML destekler)"></textarea>
                            <span class="form-text text-muted">PayTR aktif değil, EFT/havale aktifse bu metin ödeme sayfasında gösterilir.</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-md-9 offset-md-3">
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </div>
        </form>
    </div>
</section>
