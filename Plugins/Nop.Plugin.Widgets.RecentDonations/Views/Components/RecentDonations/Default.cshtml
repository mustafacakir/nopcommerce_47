@model Nop.Plugin.Widgets.RecentDonations.Models.PublicInfoModel
@{ Layout = ""; }

@if (Model.Items.Any())
{
    <section class="rdn-section">
        <div class="rdn-container">
            <div class="rdn-header">
                <div class="rdn-badge">Canlı Akış</div>
                <h2 class="rdn-title">Son Bağışlar</h2>
                <p class="rdn-sub">Topluluğumuz her gün büyüyor. Siz de katılın.</p>
            </div>
            <div class="rdn-grid">
                @foreach (var item in Model.Items)
                {
                    <div class="rdn-card">
                        <div class="rdn-avatar">@item.DonorName.Substring(0, 1).ToUpper()</div>
                        <div class="rdn-info">
                            <div class="rdn-name">@item.DonorName</div>
                            @if (!string.IsNullOrEmpty(item.ProductName))
                            {
                                <div class="rdn-product">@item.ProductName</div>
                            }
                            <div class="rdn-meta">
                                @if (!string.IsNullOrEmpty(item.Amount))
                                {
                                    <span class="rdn-amount">@item.Amount</span>
                                }
                                <span class="rdn-time">@item.TimeAgo</span>
                            </div>
                        </div>
                        <div class="rdn-heart">❤️</div>
                    </div>
                }
            </div>
        </div>
    </section>
}
else if (!string.IsNullOrEmpty(Model.FallbackText))
{
    <section class="rdn-section">
        <div class="rdn-container">
            <p class="rdn-fallback">❤️ @Model.FallbackText</p>
        </div>
    </section>
}

<style>
.rdn-section {
    background: #fff;
    padding: 72px 0 80px;
    border-top: 1px solid #ebebeb;
}
.rdn-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
}
.rdn-header {
    text-align: center;
    margin-bottom: 40px;
}
.rdn-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(135deg, #e43d51, #c0392b);
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 16px;
    border-radius: 20px;
    margin-bottom: 14px;
}
.rdn-badge::before {
    content: '';
    width: 7px;
    height: 7px;
    background: #fff;
    border-radius: 50%;
    animation: rdn-pulse 1.5s ease-in-out infinite;
    flex-shrink: 0;
}
.rdn-title {
    font-size: 28px;
    font-weight: 900;
    color: #1a1a1a;
    margin: 0 0 10px;
}
.rdn-sub {
    font-size: 14px;
    color: #888;
    margin: 0;
}
.rdn-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
}
.rdn-card {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #fafafa;
    border: 1px solid #f0f0f0;
    border-radius: 14px;
    padding: 16px 18px;
    transition: box-shadow 0.2s, transform 0.2s;
}
.rdn-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
}
.rdn-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e43d51, #c0392b);
    color: #fff;
    font-size: 18px;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.rdn-info { flex: 1; min-width: 0; }
.rdn-name {
    font-size: 14px;
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.rdn-product {
    font-size: 12px;
    color: #666;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.rdn-meta {
    display: flex;
    align-items: center;
    gap: 8px;
}
.rdn-amount {
    font-size: 13px;
    font-weight: 900;
    color: #e43d51;
}
.rdn-time {
    font-size: 11px;
    color: #bbb;
}
.rdn-heart {
    font-size: 18px;
    flex-shrink: 0;
}
.rdn-fallback {
    text-align: center;
    color: #e43d51;
    font-size: 14px;
    font-weight: 600;
}

@@keyframes rdn-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
}

@@media (max-width: 900px) {
    .rdn-grid { grid-template-columns: repeat(2, 1fr); }
}
@@media (max-width: 580px) {
    .rdn-grid { grid-template-columns: 1fr; }
}
</style>
