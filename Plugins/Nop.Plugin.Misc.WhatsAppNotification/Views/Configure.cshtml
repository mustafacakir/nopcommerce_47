@model Nop.Plugin.Misc.WhatsAppNotification.Models.ConfigureModel
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "WhatsApp Sipariş Bildirimi";
}

<div class="content-header clearfix">
    <h1 class="pull-left">WhatsApp Sipariş Bildirimi</h1>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <div class="alert alert-info">
                <strong>Şablon parametreleri:</strong>
                <code>{{1}}</code> Sipariş No &nbsp;|&nbsp;
                <code>{{2}}</code> Müşteri adı &nbsp;|&nbsp;
                <code>{{3}}</code> Sipariş tutarı &nbsp;|&nbsp;
                <code>{{4}}</code> Mağaza adı
            </div>

            <form asp-controller="WhatsAppNotification" asp-action="Configure" method="post">
                <input asp-for="ActiveStoreScopeConfiguration" type="hidden" />

                <div class="card card-default">
                    <div class="card-body">

                        <div class="form-group row">
                            <div class="col-md-3">
                                @if (Model.ActiveStoreScopeConfiguration > 0)
                                {
                                    <nop-override-store-checkbox asp-for="Enabled_OverrideForStore"
                                                                 asp-input="Enabled"
                                                                 asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                }
                                <nop-label asp-for="Enabled" />
                            </div>
                            <div class="col-md-9">
                                <nop-editor asp-for="Enabled" />
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                @if (Model.ActiveStoreScopeConfiguration > 0)
                                {
                                    <nop-override-store-checkbox asp-for="AccessToken_OverrideForStore"
                                                                 asp-input="AccessToken"
                                                                 asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                }
                                <nop-label asp-for="AccessToken" />
                            </div>
                            <div class="col-md-9">
                                <input asp-for="AccessToken" class="form-control" />
                                <span class="form-text text-muted">Meta Business → WhatsApp → API Setup → Access Token (kalıcı token)</span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                @if (Model.ActiveStoreScopeConfiguration > 0)
                                {
                                    <nop-override-store-checkbox asp-for="PhoneNumberId_OverrideForStore"
                                                                 asp-input="PhoneNumberId"
                                                                 asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                }
                                <nop-label asp-for="PhoneNumberId" />
                            </div>
                            <div class="col-md-9">
                                <input asp-for="PhoneNumberId" class="form-control" />
                                <span class="form-text text-muted">Meta Business → WhatsApp → API Setup → Phone Number ID</span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                @if (Model.ActiveStoreScopeConfiguration > 0)
                                {
                                    <nop-override-store-checkbox asp-for="RecipientPhone_OverrideForStore"
                                                                 asp-input="RecipientPhone"
                                                                 asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                }
                                <nop-label asp-for="RecipientPhone" />
                            </div>
                            <div class="col-md-9">
                                <input asp-for="RecipientPhone" class="form-control" placeholder="+905XXXXXXXXX" />
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                @if (Model.ActiveStoreScopeConfiguration > 0)
                                {
                                    <nop-override-store-checkbox asp-for="TemplateName_OverrideForStore"
                                                                 asp-input="TemplateName"
                                                                 asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                }
                                <nop-label asp-for="TemplateName" />
                            </div>
                            <div class="col-md-9">
                                <input asp-for="TemplateName" class="form-control" />
                                <span class="form-text text-muted">Meta Business Manager'da onaylattığınız şablon adı</span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                @if (Model.ActiveStoreScopeConfiguration > 0)
                                {
                                    <nop-override-store-checkbox asp-for="TemplateLanguage_OverrideForStore"
                                                                 asp-input="TemplateLanguage"
                                                                 asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                }
                                <nop-label asp-for="TemplateLanguage" />
                            </div>
                            <div class="col-md-9">
                                <input asp-for="TemplateLanguage" class="form-control" />
                                <span class="form-text text-muted">Örn: tr, en_US</span>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-md-9 offset-md-3">
                        <button type="submit" name="save" class="btn btn-primary">Kaydet</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>
